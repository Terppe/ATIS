            
<mah:MetroWindow
    x:Class="ATIS.Ui.Views.Report.ListDetails.ReportFiSpeciesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:models="clr-namespace:ATIS.Dal.Models;assembly=ATIS.Dal"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:valueConverter="clr-namespace:ATIS.Ui.Helper.ValueConverter"
    Title="{DynamicResource Report-Title}"
    Width="1250"
    Height="600"
    ResizeMode="CanResizeWithGrip">  

        <!-- ReportTbl69FiSpeciessesWindow.xaml  Skriptdatum:  15.12.2019  10:32   -->    
            
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Button.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Shadows.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.TextBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.CheckBox.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:ImageSourceConverter x:Key="ImageSourceConverter" />
            <Style BasedOn="{StaticResource MaterialDesignTextBox}" TargetType="{x:Type TextBox}">
                <Setter Property="Margin" Value="2,0,2,0" />
            </Style>
            <Style BasedOn="{StaticResource MaterialDesignListBox}" TargetType="{x:Type ListBox}">
                <Setter Property="Margin" Value="2,0,2,0" />
                <Setter Property="Height" Value="24" />
            </Style>
            <Style TargetType="{x:Type TableCell}">
                <Setter Property="Padding" Value="2" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>  
             
    <Grid x:Name="LayoutRoot">
        <Grid.Resources>
            <valueConverter:AuthorConverter x:Key="AuthorConverter" />
            <valueConverter:AuthorWithoutStringConverter x:Key="AuthorWithoutStringConverter" />
            <valueConverter:NameConverter x:Key="NameConverter" />
            <valueConverter:DateConverter x:Key="DateConverter" />
            <valueConverter:TimeConverter x:Key="TimeConverter" />
            <valueConverter:BooleanToVisibilityConverter
                x:Key="BooleanToVisibilityConverter"
                False="Collapsed"
                True="Visible" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions> 
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            DockPanel.Dock="Top"
            Orientation="Horizontal">
            <TextBox
                x:Name="Reader"
                Margin="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                mah:TextBoxHelper.IsWaitingForData="True"
                mah:TextBoxHelper.UseFloatingWatermark="True"
                mah:TextBoxHelper.Watermark="Reader"
                mah:TextBoxHelper.WatermarkAlignment="Left"
                FontWeight="Medium"
                LostFocus="Reader_LostFocus"
                SpellCheck.IsEnabled="True"
                Text="1050"
                ToolTip="Reader" />

            <TextBox
                x:Name="PageWidthText"
                Margin="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                mah:TextBoxHelper.IsWaitingForData="True"
                mah:TextBoxHelper.UseFloatingWatermark="True"
                mah:TextBoxHelper.Watermark="PageWidthText"
                mah:TextBoxHelper.WatermarkAlignment="Left"
                FontWeight="Medium"
                SpellCheck.IsEnabled="True"
                Text="1200"
                ToolTip="PageWidthText" />

            <TextBox
                x:Name="PagePaddingText"
                Margin="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                mah:TextBoxHelper.IsWaitingForData="True"
                mah:TextBoxHelper.UseFloatingWatermark="True"
                mah:TextBoxHelper.Watermark="PagePaddingText"
                mah:TextBoxHelper.WatermarkAlignment="Left"
                FontWeight="Medium"
                SpellCheck.IsEnabled="True"
                Text="28"
                ToolTip="PagePaddingText" />

            <TextBox
                x:Name="ColumnWidthText"
                Margin="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                mah:TextBoxHelper.IsWaitingForData="True"
                mah:TextBoxHelper.UseFloatingWatermark="True"
                mah:TextBoxHelper.Watermark="ColumnWidthText"
                mah:TextBoxHelper.WatermarkAlignment="Left"
                FontWeight="Medium"
                SpellCheck.IsEnabled="True"
                Text="800"
                ToolTip="ColumnWidthText" />

            <CheckBox
                x:Name="FlexibleChecked"
                VerticalAlignment="Center"
                Content="{DynamicResource ReportFlow-ColumnWidthFlex}"
                IsChecked="True"
                Style="{StaticResource MahApps.Styles.CheckBox}" />
            <Button
                Width="100"
                Margin="100,5,10,5"
                VerticalAlignment="Center"
                Click="Print_Click"
                Content="{DynamicResource Shared-ButtonPrint}"
                Style="{StaticResource MahApps.Styles.Button}" />
            <Button
                Width="120"
                Margin="5,5,10,5"
                VerticalAlignment="Center"
                Command="{Binding PdfFiSpeciesPrintCommand}"
                Content="{DynamicResource Report-PrintPdf}"
                Style="{StaticResource MahApps.Styles.Button}" />
            <Button
                Width="120"
                Margin="5,5,10,5"
                VerticalAlignment="Center"
                Command="{Binding PdfFiSpeciesSaveCommand}"
                Content="{DynamicResource Report-SavePdf}"
                Style="{StaticResource MahApps.Styles.Button}" />
        </StackPanel>        

                
   <!--   Part 1  -->     
                                                                                                                                                
             
        <FlowDocumentReader
            Grid.Row="1"
            Width="{Binding ElementName=ReaderWidthText, Path=Text, UpdateSourceTrigger=LostFocus}"
            Margin="5,10"
            BorderBrush="Black"
            BorderThickness="0.5"
            IsPageViewEnabled="False"
            IsPrintEnabled="True"
            IsTwoPageViewEnabled="False"
            ViewingMode="Scroll"
            Zoom="100">
            <FlowDocument
                x:Name="FlowDocument"
                Background="White"
                ColumnWidth="{Binding ElementName=ColumnWidthText, Path=Text}"
                FontFamily="Arial"
                FontSize="12"
                IsColumnWidthFlexible="{Binding ElementName=FlexibleChecked, Path=IsChecked}"
                PagePadding="{Binding ElementName=PagePaddingText, Path=Text}"
                PageWidth="{Binding ElementName=PageWidthText, Path=Text}">
                <Section FontSize="14pt">
                    <Paragraph TextAlignment="Left">
                        <TextBlock
                            Width="{Binding ElementName=PageWidthText, Path=Text}"
                            Margin="10,0,0,0"
                            FontWeight="Bold"
                            Text="{DynamicResource Report-Title}" />
                    </Paragraph>
                </Section>                                                  
             
                <Section>
                    <Paragraph>
                        <GroupBox>            
                          <ListBox
                            Width="{Binding ElementName=PageWidthText, Path=Text}"
                            Height="Auto"
                            Margin="0"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding FiSpeciessesCollection}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <StackPanel Margin="2,0,0,0" Orientation="Horizontal">
                                            <TextBlock
                                                Width="Auto"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="{Binding (models:Tbl69FiSpecies.Tbl66Genusses).GenusName}" />            
                                            <TextBlock
                                                Width="Auto"
                                                Margin="2,0,0,0"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="{Binding (models:Tbl69FiSpecies.FiSpeciesName)}" />            
                                            <TextBlock
                                                Width="Auto"
                                                Margin="2,0,0,0"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="{Binding (models:Tbl69FiSpecies.Subspecies)}" />            
                                            <TextBlock
                                                Width="Auto"
                                                Margin="2,0,0,0"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="{Binding (models:Tbl69FiSpecies.Divers)}" />            
                                                <TextBlock
                                                    Width="Auto"
                                                    Margin="2,0,0,0"
                                                    FontSize="18"
                                                    FontWeight="Bold">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource AuthorWithoutStringConverter}">
                                                            <Binding Path="Author" />
                                                            <Binding Path="AuthorYear" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                        </StackPanel>
                                        <StackPanel  Orientation="Horizontal">
                                            <TextBlock Width="Auto" Text="{DynamicResource Report-TaxonomicId}" />
                                            <TextBlock Width="Auto" Text="{Binding (models:Tbl69FiSpecies.CountId)}" />            
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                         </ListBox>
                        </GroupBox>
                  </Paragraph>
              </Section>  

             
   <!--   Part 2  -->     
                    
             
