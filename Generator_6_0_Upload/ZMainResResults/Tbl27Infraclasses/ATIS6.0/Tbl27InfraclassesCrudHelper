            };
            return home;
        }
        public void LegioSave(Tbl30Legio home, Tbl30Legio selected)
        {
            if (selected.InfraclassId != 0) //update
            {
                _uow.Tbl30Legios.Update(home);
            }
            else                                //add
                _uow.Tbl30Legios.Add(home);
            _uow.Complete();
        }

