        private ObservableCollection<T> GetGeographicsCollectionFromSearchNameOrIdOrderBy<T>(string searchName)
        {
            ObservableCollection<T> collection;
            collection = int.TryParse(searchName, out var id)
                ? new ObservableCollection<T>((IEnumerable<T>)_uow.Tbl87Geographics
                    .Find(e => e.GeographicId == id))
                : new ObservableCollection<T>((IEnumerable<T>)_uow.Tbl87Geographics
                    .Find(e => e.GeographicName.StartsWith(searchName))
                    .OrderBy(a => a.GeographicName)
                );
            return collection;
        }

