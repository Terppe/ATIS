        public void SupertribusSave(Tbl54Supertribus home, Tbl54Supertribus selected)
        {

            if (selected.SupertribusId != 0) //update
            {
                _uow.Tbl54Supertribusses.Update(home);
            }
            else                                //add
                _uow.Tbl54Supertribusses.Add(home);
            _uow.Complete();
        }

