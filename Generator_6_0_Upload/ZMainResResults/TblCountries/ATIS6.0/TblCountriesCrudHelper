        private ObservableCollection<T> GetCountriesCollectionFromSearchNameOrIdOrderBy<T>(string searchName)
        {
            ObservableCollection<T> collection;
            collection = int.TryParse(searchName, out var id)
                ? new ObservableCollection<T>((IEnumerable<T>)_uow.TblCountries
                    .Find(e => e.CountryId == id))
                : new ObservableCollection<T>((IEnumerable<T>)_uow.TblCountries
                    .Find(e => e.CountryName.StartsWith(searchName))
                    .OrderBy(a => a.CountryName)
                );
            return collection;
        }

        private ObservableCollection<T> GetCountriesCollectionAllOrderBy<T>()
        {
            ObservableCollection<T> collection;
            collection = new ObservableCollection<T>((IEnumerable<T>)_context.TblCountries
                .OrderBy(a => a.CountryName));
            return collection;
        }
        public ObservableCollection<T> GetCountriesCollectionFromCountryIdOrderBy<T>(int id)
        {
            ObservableCollection<T> collection;
            collection = new ObservableCollection<T>((IEnumerable<T>)_context.TblCountries
