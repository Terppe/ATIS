           
                 ------- ControlTemplateButtons---------------
    <!--  Phylum-->
    <ControlTemplate x:Key="SearchPhylumsButton" TargetType="Button">   
        <Button
            Width="36"
            Height="36"
            Margin="4"
            Command="{Binding GetPhylumsByNameOrIdCommand}"
            Foreground="{DynamicResource MahApps.Brushes.Accent}"
            IsEnabled="True"
            Style="{StaticResource MahApps.Styles.Button.Circle}">
            <Button.ContentTemplate>
                <DataTemplate>
                    <iconPacks:PackIconModern
                        Width="20"
                        Height="20"
                        Kind="PageSearch" />
                </DataTemplate>
            </Button.ContentTemplate>
        </Button>
    </ControlTemplate>

