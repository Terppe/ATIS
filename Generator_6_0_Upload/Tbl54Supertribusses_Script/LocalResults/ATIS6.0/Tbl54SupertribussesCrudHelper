        public void TribusSave(Tbl57Tribus home, Tbl57Tribus selected)
        {
            if (selected.SupertribusId != 0) //update
            {
                _uow.Tbl57Tribusses.Update(home);
            }
            else                                //add
                _uow.Tbl57Tribusses.Add(home);
            _uow.Complete();
        }

