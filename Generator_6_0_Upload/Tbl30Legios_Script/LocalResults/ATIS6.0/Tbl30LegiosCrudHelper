        public void OrdoSave(Tbl33Ordo home, Tbl33Ordo selected)
        {
            if (selected.LegioId != 0) //update
            {
                _uow.Tbl33Ordos.Update(home);
            }
            else                                //add
                _uow.Tbl33Ordos.Add(home);
            _uow.Complete();
        }

