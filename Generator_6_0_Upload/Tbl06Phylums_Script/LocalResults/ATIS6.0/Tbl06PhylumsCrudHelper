        public void SubphylumSave(Tbl12Subphylum home, Tbl12Subphylum selected)
        {
            if (selected.PhylumId != 0) //update
            {
                _uow.Tbl12Subphylums.Update(home);
            }
            else                                //add
                _uow.Tbl12Subphylums.Add(home);
            _uow.Complete();
        }

