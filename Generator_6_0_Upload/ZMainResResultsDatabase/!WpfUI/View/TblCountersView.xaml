                                                            <materialDesign:PackIcon
                                                                Width="24"
                                                                Height="24"
                                                                Margin="0,0,-5,0"
                                                                Opacity=".56"
                                                                Kind="Delete" />
                                                        </Button>
                                                    </StackPanel>
                                                    <StackPanel Height="Auto" Orientation="Horizontal">
                                                        <ComboBox
                                                            Width="500"
                                                            Margin="5,0,0,0"
                                                            VerticalAlignment="Bottom"
                                                            Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                                            materialDesign:HintAssist.Hint="{DynamicResource Shared-Author}"
                                                            IsSynchronizedWithCurrentItem="True"
                                                            ItemsSource="{Binding Tbl90AuthorsAllList}"
                                                            SelectedValue="{Binding SelectedItem.(models:Tbl90RefAuthor.RefAuthorID), ElementName=Tbl90RefAuthorsList, Mode=TwoWay}"
                                                            SelectedValuePath="RefAuthorID">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding RefAuthorName}" />
                                                                        <TextBlock Margin="2,0,0,0" Text="{Binding BookName}" />
                                                                        <TextBlock Margin="2,0,0,0" Text="{Binding Page1}" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                        <CheckBox
                                                            Width="75"
                                                            Margin="25,0,0,0"
                                                            VerticalAlignment="Bottom"
                                                            Style="{StaticResource MaterialDesignCheckBox}"
                                                            Content="{DynamicResource Shared-Valid}"
                                                            IsChecked="{Binding SelectedItem.(models:Tbl90RefAuthor.Valid), ElementName=Tbl90RefAuthorsList}" />
                                                        <TextBox
                                                            Width="135"
                                                            Margin="25,0,0,0"
                                                            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                            materialDesign:HintAssist.Hint="{DynamicResource Shared-ValidYear}"
                                                            Text="{Binding SelectedItem.(models:Tbl90RefAuthor.ValidYear), ElementName=Tbl90RefAuthorsList}" />
                                                    </StackPanel>
                                                    <StackPanel Height="Auto" Orientation="Horizontal">
                                                        <TextBox
                                                            Width="760"
                                                            Margin="5,0,0,0"
                                                            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                            materialDesign:HintAssist.Hint="{DynamicResource Shared-Info}"
                                                            Text="{Binding SelectedItem.(models:Tbl90RefAuthor.Info), ElementName=Tbl90RefAuthorsList}" />
                                                    </StackPanel>
     
             
                                                    <StackPanel Height="Auto" Orientation="Horizontal">
                                                        <TextBox
                                                            Height="277"
                                                            MinWidth="760"
                                                            Margin="5,0,0,10"
                                                            VerticalAlignment="Stretch"
                                                            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                            materialDesign:HintAssist.Hint="{DynamicResource Shared-Memo}"
                                                            AcceptsReturn="True"
                                                            Text="{Binding SelectedItem.(models:Tbl90RefAuthor.Memo), ElementName=Tbl90RefAuthorsList}"
                                                            TextWrapping="Wrap"
                                                            VerticalScrollBarVisibility="Auto" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </HeaderedContentControl.Header>
                                        </HeaderedContentControl>
                                    </TabItem>
                                </dragablz:TabablzControl>
                            </TabItem>               
          
                            <!--  Part 14  -->

                            <TabItem Header="{DynamicResource Tbl93Comment-Comment}">              
                                <HeaderedContentControl>
                                    <HeaderedContentControl.Header>
                                        <StackPanel>
                                            <StackPanel Height="Auto" Orientation="Horizontal">
                                                        <ComboBox
                                                            Width="500"
                                                            Margin="5,0,0,0"
                                                            VerticalAlignment="Bottom"
                                                            Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                                            materialDesign:HintAssist.Hint="{DynamicResource TblCounter-CounterName}"            
                                                            IsSynchronizedWithCurrentItem="True"
                                                            ItemsSource="{Binding TblCountersAllList}"
                                                            SelectedValue="{Binding SelectedItem.(models:TblCounter.CounterID), ElementName=Tbl93CommentsList, Mode=TwoWay}"
                                                            SelectedValuePath="CounterID">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding CounterName}" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>     
                                                <Button
                                                    Margin="40,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Command="{Binding SaveCommentCommand}"
                                                    ToolTip="{DynamicResource Shared-ButtonSave}">
                                                    <materialDesign:PackIcon
                                                        Width="24"
                                                        Height="24"
                                                        Margin="0,0,-5,0"
                                                        Opacity=".56"
                                                        Kind="ContentSave" />
                                                </Button>
                                                <Button
                                                    Margin="0,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Command="{Binding CopyCommentCommand}"
                                                    ToolTip="{DynamicResource Shared-ActionLnkCopy}">
                                                    <materialDesign:PackIcon
                                                        Width="24"
                                                        Height="24"
                                                        Margin="0,0,-5,0"
                                                        Opacity=".56"
                                                        Kind="ContentCopy" />
                                                </Button>
                                                <Button
                                                    Margin="0,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Command="{Binding AddCommentCommand}"
                                                    ToolTip="{DynamicResource Shared-ActionLnkCreate}">
                                                    <materialDesign:PackIcon
                                                        Width="24"
                                                        Height="24"
                                                        Margin="0,0,-5,0"
                                                        Opacity=".56"
                                                        Kind="Plus" />
                                                </Button>
                                                <Button
                                                    Margin="0,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    Style="{StaticResource MaterialDesignFlatButton}"
                                                    Command="{Binding DeleteCommentCommand}"
                                                    ToolTip="{DynamicResource Shared-ActionLnkDelete}">
                                                    <materialDesign:PackIcon
                                                        Width="24"
                                                        Height="24"
                                                        Margin="0,0,-5,0"
                                                        Opacity=".56"
                                                        Kind="Delete" />
                                                </Button>
                                            </StackPanel>
                                            <StackPanel Height="Auto" Orientation="Horizontal">
                                                <CheckBox
                                                    Width="80"
                                                    Margin="5,0,0,0"
                                                    VerticalAlignment="Bottom"
                                                    Style="{StaticResource MaterialDesignCheckBox}"
                                                    Content="{DynamicResource Shared-Valid}"
                                                    IsChecked="{Binding SelectedItem.(models:Tbl93Comment.Valid), ElementName=Tbl93CommentsList}" />
                                                <TextBox
                                                    Width="135"
                                                    Margin="25,0,0,0"
                                                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                    materialDesign:HintAssist.Hint="{DynamicResource Shared-ValidYear}"
                                                    Text="{Binding SelectedItem.(models:Tbl93Comment.ValidYear), ElementName=Tbl93CommentsList}" />
                                            </StackPanel>
                                            <StackPanel Height="Auto" Orientation="Horizontal">
                                                <TextBox
                                                    Width="760"
                                                    Margin="5,0,0,0"
                                                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                    materialDesign:HintAssist.Hint="{DynamicResource Shared-Info}"
                                                    Text="{Binding SelectedItem.(models:Tbl93Comment.Info), ElementName=Tbl93CommentsList}" />
                                            </StackPanel>              
          
                                            <StackPanel Height="Auto" Orientation="Horizontal">
                                                <TextBox
                                                    Height="320"
                                                    MinWidth="760"
                                                    Margin="5,0,0,10"
                                                    VerticalAlignment="Stretch"
                                                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                                    materialDesign:HintAssist.Hint="{DynamicResource Shared-Memo}"
                                                    AcceptsReturn="True"
                                                    Text="{Binding SelectedItem.(models:Tbl93Comment.Memo), ElementName=Tbl93CommentsList}"
                                                    TextWrapping="Wrap"
                                                    VerticalScrollBarVisibility="Auto" />
                                            </StackPanel>
                                        </StackPanel>
                                    </HeaderedContentControl.Header>
                                </HeaderedContentControl>
                            </TabItem>              
        
                        </dragablz:TabablzControl>
                                </ContentControl>
                            </TabItem>
                        </dragablz:TabablzControl>
                 </StackPanel>
                </ContentControl>
     </DockPanel>
            
        
      </Grid>
   </ScrollViewer>
  </Grid>
</UserControl>
            
