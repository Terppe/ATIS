@model Atis.Domain.ViewModels.Tbl18Superclasses.ListViewModel

        <!-- Index  Skriptdatum:  15.03.2012  12:32   -->    
    

@{
    ViewBag.Title =  Tbl18SuperclassesRes.StringsRes.Index;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>@Tbl18SuperclassesRes.StringsRes.Index</h2>

@using (Html.BeginForm("Index", "Tbl18Superclasses", FormMethod.Get))              
{
    <fieldset class="filtering">
        <legend>@SharedRes.StringsRes.Filter</legend>  
        <div> 
            <p></p>         
 
            <table>                                             
                <tr>  
                    <td style="width:9em"><strong>@Tbl18SuperclassesRes.StringsRes.SuperclassID </strong></td>
                    <td><input type="text" id="superclassid" name="superclassid" /></td>            
                    <td style="width:13em"><strong>@Tbl18SuperclassesRes.StringsRes.SuperclassName </strong></td>
                    <td><input type="text" id="superclassname" name="superclassname" /></td>            
                </tr>  
            </table>                                             
            <table>                                             
                <tr>              
                    <td style="width:8em"><strong>@Tbl12SubphylumsRes.StringsRes.SubphylumName </strong></td>
                    <td>@Html.DropDownListFor(m => m.SubphylumID, Model.SubphylumList, SharedRes.StringsRes.DDLAll, new { @class = "ddl15" })     </td>      
                    <td style="width:8em"><strong>@Tbl15SubdivisionsRes.StringsRes.SubdivisionName </strong></td>
                    <td>@Html.DropDownListFor(m => m.SubdivisionID, Model.SubdivisionList, SharedRes.StringsRes.DDLAll, new { @class = "ddl15" })     </td>      
  
                    <td style="width:4em"><strong>@SharedRes.StringsRes.Valid </strong></td>
                    <td>@Html.EditorFor(m => m.Valid)</td>

                    @Html.Hidden("sortBy", Model.SortBy)
                    @Html.Hidden("ascending", Model.SortAscending)

                    <td><input type="submit" value="@SharedRes.StringsRes.Search" /></td> 
                </tr>   
            </table>        
 
        </div>
    </fieldset>
}

<table class="grid" style="width: 95%">                
    <tr>
        <th></th>   
 
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "SuperclassName" }, { "DisplayName", Tbl18SuperclassesRes.StringsRes.SuperclassName } })</th>                    
 
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "Author" }, { "DisplayName", SharedRes.StringsRes.Author } })</th>
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "AuthorYear" }, { "DisplayName", SharedRes.StringsRes.AuthorYear } })</th>  
 
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "Valid" }, { "DisplayName", SharedRes.StringsRes.Valid } })</th>
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "ValidYear" }, { "DisplayName", SharedRes.StringsRes.ValidYear } })</th>   
  
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "SubphylumID" }, { "DisplayName", Tbl12SubphylumsRes.StringsRes.SubphylumName } })</th>
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "SubdivisionID" }, { "DisplayName", Tbl15SubdivisionsRes.StringsRes.SubdivisionName } })</th>                 

     </tr>

    @foreach (var item in Model.Tbl18Superclasses) { 
    
    <tr>
        <td class="left">
            @Html.ActionLink(SharedRes.StringsRes.ActionLnkDelete, "Delete", new { id = item.SuperclassID }) | 
            @Html.ActionLink(SharedRes.StringsRes.ActionLnkEdit, "Edit", new { id = item.SuperclassID }) |
            @Html.ActionLink(SharedRes.StringsRes.ActionLnkDetails, "Details", new { id = item.SuperclassID }) </td>           

 
        <td class="left">@item.SuperclassName </td>                    
 
        <td class="left">@item.Author</td>       
        <td class="align-middle">@item.AuthorYear</td>        
  
 
        <td class="align-middle">
        @if (item.Valid == true) { 
                <img src="@Url.Content("~/Content/Images/Ok.png")" alt="@SharedRes.StringsRes.ValidYes" title="@SharedRes.StringsRes.ValidYes" />   } 
            else { 
                <img src="@Url.Content("~/Content/Images/cancel.png")" alt="@SharedRes.StringsRes.ValidNo" title="@SharedRes.StringsRes.ValidNo" />   
           } 
         </td>
        <td class="align-middle">@item.ValidYear</td>   
  
        @if (!item.Tbl12Subphylums.SubphylumName.StartsWith("#"))  {
            <td class="left">@item.Tbl12Subphylums.SubphylumName  </td>
            <td class="left"></td>  }
        else {
            <td class="left"></td>  
            <td class="left">@item.Tbl15Subdivisions.SubdivisionName  </td>  }    

    </tr>    
    }     
    <tr>        
  
        <td class="pager" colspan="9">   
 
           @Html.Partial("_Pager", Model)
        </td>
    </tr>       
</table>
<div>
    <ul id="nav-one" class="dropmenu css-only">      

         <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkSubphylumLeft, "Index", "Tbl12Subphylums")</li>        
  
         <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkSubdivisionLeft, "Index", "Tbl15Subdivisions")</li>      
  
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkClassRight, "Index", "Tbl21Classes")</li>      
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkClassCreateRight, "Create", "Tbl21Classes", new { superclassId = 0 }, null)</li>  
    
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkReferenceRight, "Index", "Tbl90References")</li>                       
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkReferenceCreateRight, "Create", "Tbl90References",
            new { regnumId = 0,
                      phylumId = 0,
                      divisionId = 0,
                      subphylumId = 0,
                      subdivisionId = 0,
                      superclassId = 0,
                      classId = 0,
                      subclassId = 0,
                      infraclassId = 0,
                      legioId = 0,
                      ordoId = 0,
                      subordoId = 0,
                      infraordoId = 0,
                      superfamilyId = 0,
                      familyId = 0,
                      subfamilyId = 0,
                      infrafamilyId = 0,
                      supertribusId = 0,
                      tribusId = 0,
                      subtribusId = 0,
                      infratribusId = 0,
                      genusId = 0,
                      fispeciesId = 0,
                      plspeciesId = 0
            }, null)</li>               
 
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkCommentRight, "Index", "Tbl93Comments")</li>                       
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkCommentCreateRight, "Create", "Tbl93Comments",
            new { regnumId = 0,
                      phylumId = 0,
                      divisionId = 0,
                      subphylumId = 0,
                      subdivisionId = 0,
                      superclassId = 0,
                      classId = 0,
                      subclassId = 0,
                      infraclassId = 0,
                      legioId = 0,
                      ordoId = 0,
                      subordoId = 0,
                      infraordoId = 0,
                      superfamilyId = 0,
                      familyId = 0,
                      subfamilyId = 0,
                      infrafamilyId = 0,
                      supertribusId = 0,
                      tribusId = 0,
                      subtribusId = 0,
                      infratribusId = 0,
                      genusId = 0,
                      fispeciesId = 0,
                      plspeciesId = 0
            }, null)</li>               
   
  
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkCreate, "Create", "Tbl18Superclasses", new { subphylumId = 0, subdivisionId = 0 }, null)</li>   
    </ul> 
</div>        
