@model Atis.Domain.ViewModels.Tbl84Synonyms.ListViewModel

        <!-- Index  Skriptdatum:  15.03.2012  10:32   -->    
    

@{
    ViewBag.Title =  Tbl84SynonymsRes.StringsRes.Index;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>@Tbl84SynonymsRes.StringsRes.Index</h2>

@using (Html.BeginForm("Index", "Tbl84Synonyms", FormMethod.Get))              
{
    <fieldset class="filtering">
        <legend>@SharedRes.StringsRes.Filter</legend>  
        <div> 
            <p></p>         
 
            <table>                                             
                <tr>  
                    <td style="width:7.9em"><strong>@Tbl84SynonymsRes.StringsRes.SynonymID </strong></td>
                    <td><input type="text" id="synonymid" name="synonymid" /></td>            
                    <td style="width:11.9em"><strong>@Tbl84SynonymsRes.StringsRes.SynonymName </strong></td>
                    <td><input type="text" id="synonymname" name="synonymname" /></td>            
                </tr>  
            </table>                                             
            <table>                                             
                <tr>              
                    <td style="width:8em"><strong>@Tbl69FiSpeciessesRes.StringsRes.FiSpeciesName </strong></td>
                    <td>@Html.DropDownListFor(m => m.FiSpeciesID, Model.FiSpeciesList, SharedRes.StringsRes.DDLAll, new { @class = "ddl15" })     </td>      
                    <td style="width:8em"><strong>@Tbl72PlSpeciessesRes.StringsRes.PlSpeciesName </strong></td>
                    <td>@Html.DropDownListFor(m => m.PlSpeciesID, Model.PlSpeciesList, SharedRes.StringsRes.DDLAll, new { @class = "ddl15" })     </td>            
  
                    <td style="width:4em"><strong>@SharedRes.StringsRes.Valid </strong></td>
                    <td>@Html.EditorFor(m => m.Valid)</td>

                    @Html.Hidden("sortBy", Model.SortBy)
                    @Html.Hidden("ascending", Model.SortAscending)

                    <td><input type="submit" value="@SharedRes.StringsRes.Search" /></td> 
                </tr>   
            </table>        
 
        </div>
    </fieldset>
}

<table class="grid" style="width: 95%">                
    <tr>
        <th></th>   
 
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "SynonymName" }, { "DisplayName", Tbl84SynonymsRes.StringsRes.SynonymName } })</th>                    
 
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "Author" }, { "DisplayName", SharedRes.StringsRes.Author } })</th>
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "AuthorYear" }, { "DisplayName", SharedRes.StringsRes.AuthorYear } })</th>  
 
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "Valid" }, { "DisplayName", SharedRes.StringsRes.Valid } })</th>
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "ValidYear" }, { "DisplayName", SharedRes.StringsRes.ValidYear } })</th>   
  
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "FiSpeciesID" }, { "DisplayName", SharedRes.StringsRes.FiPl } })</th>                 

     </tr>

    @foreach (var item in Model.Tbl84Synonyms) { 
    
    <tr>
        <td class="left">
            @Html.ActionLink(SharedRes.StringsRes.ActionLnkDelete, "Delete", new { id = item.SynonymID }) | 
            @Html.ActionLink(SharedRes.StringsRes.ActionLnkEdit, "Edit", new { id = item.SynonymID }) |
            @Html.ActionLink(SharedRes.StringsRes.ActionLnkDetails, "Details", new { id = item.SynonymID }) </td>           

 
        <td class="left">@item.SynonymName </td>                    
 
        <td class="left">@item.Author</td>       
        <td class="align-middle">@item.AuthorYear</td>        
  
 
        <td class="align-middle">
        @if (item.Valid == true) { 
                <img src="@Url.Content("~/Content/Images/Ok.png")" alt="@SharedRes.StringsRes.ValidYes" title="@SharedRes.StringsRes.ValidYes" />   } 
            else { 
                <img src="@Url.Content("~/Content/Images/cancel.png")" alt="@SharedRes.StringsRes.ValidNo" title="@SharedRes.StringsRes.ValidNo" />   
           } 
         </td>
        <td class="align-middle">@item.ValidYear</td>   
  
        
        @if (! item.Tbl69FiSpeciesses.FiSpeciesName.Contains("#")) { 
        <td class="left">@item.Tbl69FiSpeciesses.Tbl66Genusses.GenusName @item.Tbl69FiSpeciesses.FiSpeciesName @item.Tbl69FiSpeciesses.Subspecies @item.Tbl69FiSpeciesses.Divers   </td>   }
            else  { 
        <td class="left">@item.Tbl72PlSpeciesses.Tbl66Genusses.GenusName @item.Tbl72PlSpeciesses.PlSpeciesName @item.Tbl72PlSpeciesses.Subspecies @item.Tbl72PlSpeciesses.Divers   </td>    }                   

    </tr>    
    }     
    <tr>        
  
        <td class="pager" colspan="9">   
 
           @Html.Partial("_Pager", Model)
        </td>
    </tr>       
</table>
<div>
    <ul id="nav-one" class="dropmenu css-only">      

         <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkFiSpeciesLeft, "Index", "Tbl69FiSpeciesses")</li>        
  
         <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkPlSpeciesLeft, "Index", "Tbl72PlSpeciesses")</li>      
  
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkNameRight, "Index", "Tbl78Names")</li>      
  
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkImageRight, "Index", "Tbl81Images")</li>      
  
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkGeographicRight, "Index", "Tbl87Geographics")</li>      
    
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkReferenceRight, "Index", "Tbl90References")</li>                       
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkReferenceCreateRight, "Create", "Tbl90References",
            new { regnumId = 0,
                      phylumId = 0,
                      divisionId = 0,
                      subphylumId = 0,
                      subdivisionId = 0,
                      superclassId = 0,
                      classId = 0,
                      subclassId = 0,
                      infraclassId = 0,
                      legioId = 0,
                      ordoId = 0,
                      subordoId = 0,
                      infraordoId = 0,
                      superfamilyId = 0,
                      familyId = 0,
                      subfamilyId = 0,
                      infrafamilyId = 0,
                      supertribusId = 0,
                      tribusId = 0,
                      subtribusId = 0,
                      infratribusId = 0,
                      genusId = 0,
                      fispeciesId = 0,
                      plspeciesId = 0
            }, null)</li>               
 
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkCommentRight, "Index", "Tbl93Comments")</li>                       
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkCommentCreateRight, "Create", "Tbl93Comments",
            new { regnumId = 0,
                      phylumId = 0,
                      divisionId = 0,
                      subphylumId = 0,
                      subdivisionId = 0,
                      superclassId = 0,
                      classId = 0,
                      subclassId = 0,
                      infraclassId = 0,
                      legioId = 0,
                      ordoId = 0,
                      subordoId = 0,
                      infraordoId = 0,
                      superfamilyId = 0,
                      familyId = 0,
                      subfamilyId = 0,
                      infrafamilyId = 0,
                      supertribusId = 0,
                      tribusId = 0,
                      subtribusId = 0,
                      infratribusId = 0,
                      genusId = 0,
                      fispeciesId = 0,
                      plspeciesId = 0
            }, null)</li>               
 
  
        <li>@Html.ActionLink(SharedRes.StringsRes.ActionLnkCreate, "Create", "Tbl84Synonyms", new { fispeciesId = 0 }, null)</li>   
    </ul> 
</div>   
