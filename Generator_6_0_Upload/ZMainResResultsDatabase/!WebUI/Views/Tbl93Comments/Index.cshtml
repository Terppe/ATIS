<table class="grid" style="width: 95%">                
    <tr>
        <th></th>   
  
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "Memo" }, { "DisplayName", SharedRes.StringsRes.Memo } })</th>   
 
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "Valid" }, { "DisplayName", SharedRes.StringsRes.Valid } })</th>
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "ValidYear" }, { "DisplayName", SharedRes.StringsRes.ValidYear } })</th>   
  
        <th>@Html.Partial("_SmartLink", Model, new ViewDataDictionary { { "ColumnName", "" }, { "DisplayName", Tbl93CommentsRes.StringsRes.Taxo } })</th>                 

     </tr>

    @foreach (var item in Model.Tbl93Comments) { 
    
    <tr>
        <td class="left">
            @Html.ActionLink(SharedRes.StringsRes.ActionLnkDelete, "Delete", new { id = item.CommentID }) | 
            @Html.ActionLink(SharedRes.StringsRes.ActionLnkEdit, "Edit", new { id = item.CommentID }) |
            @Html.ActionLink(SharedRes.StringsRes.ActionLnkDetails, "Details", new { id = item.CommentID }) </td>           

  
        <td class="left">@item.Memo</td>       
  
 
        <td class="align-middle">
        @if (item.Valid == true) { 
                <img src="@Url.Content("~/Content/Images/Ok.png")" alt="@SharedRes.StringsRes.ValidYes" title="@SharedRes.StringsRes.ValidYes" />   } 
            else { 
                <img src="@Url.Content("~/Content/Images/cancel.png")" alt="@SharedRes.StringsRes.ValidNo" title="@SharedRes.StringsRes.ValidNo" />   
           } 
         </td>
        <td class="align-middle">@item.ValidYear</td>   
  
         <td class="left">
        @if (item.FiSpeciesID != null)
            {   <p>@item.Tbl69FiSpeciesses.Tbl66Genusses.GenusName @item.Tbl69FiSpeciesses.FiSpeciesName  @item.Tbl69FiSpeciesses.Subspecies @item.Tbl69FiSpeciesses.Divers   </p>}
        @if (item.PlSpeciesID != null)
            {   <p>@item.Tbl72PlSpeciesses.Tbl66Genusses.GenusName @item.Tbl72PlSpeciesses.PlSpeciesName  @item.Tbl72PlSpeciesses.Subspecies @item.Tbl72PlSpeciesses.Divers   </p>}
        @if (item.GenusID != null)
            {   @item.Tbl66Genusses.GenusName   }
        @if (item.InfratribusID != null)
            {   @item.Tbl63Infratribusses.InfratribusName   }
        @if (item.SubtribusID != null)
            {   @item.Tbl60Subtribusses.SubtribusName   }
        @if (item.TribusID != null)
            {   @item.Tbl57Tribusses.TribusName   }
        @if (item.SupertribusID != null)
            {   @item.Tbl54Supertribusses.SupertribusName   }
        @if (item.InfrafamilyID != null)
            {   @item.Tbl51Infrafamilies.InfrafamilyName   }
        @if (item.SubfamilyID != null)
            {   @item.Tbl48Subfamilies.SubfamilyName   }
        @if (item.FamilyID != null)
            {   @item.Tbl45Families.FamilyName   }
        @if (item.SuperfamilyID != null)
            {   @item.Tbl42Superfamilies.SuperfamilyName   }
        @if (item.InfraordoID != null)
            {   @item.Tbl39Infraordos.InfraordoName   }
        @if (item.SubordoID != null)
            {   @item.Tbl36Subordos.SubordoName   }
        @if (item.OrdoID != null)
            {   @item.Tbl33Ordos.OrdoName   }
        @if (item.LegioID != null)
            {   @item.Tbl30Legios.LegioName   }
        @if (item.InfraclassID != null)
            {   @item.Tbl27Infraclasses.InfraclassName   }
        @if (item.SubclassID != null)
            {   @item.Tbl24Subclasses.SubclassName   }
        @if (item.ClassID != null)
            {   @item.Tbl21Classes.ClassName   }
        @if (item.SuperclassID != null)
            {   @item.Tbl18Superclasses.SuperclassName   }
        @if (item.SubdivisionID != null)
            {   @item.Tbl15Subdivisions.SubdivisionName   }
        @if (item.SubphylumID != null)
            {   @item.Tbl12Subphylums.SubphylumName   }
        @if (item.DivisionID != null)
            {   @item.Tbl09Divisions.DivisionName   }
        @if (item.PhylumID != null)
            {   @item.Tbl06Phylums.PhylumName   }
        @if (item.RegnumID != null)
            {   @item.Tbl03Regnums.RegnumName   }
       </td>                 

    </tr>    
    }     
    <tr>        
  
        <td class="pager" colspan="9">   
 
