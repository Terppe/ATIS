            
<Window 
    x:Class="Te.Atis.Ui.Desktop.Views.Report.ReportTbl81ImagesWindow"               
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Te.Atis.Ui.Desktop.Domain.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:models="clr-namespace:Te.Atis.DomainModel;assembly=Te.Atis.DomainModel"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="{DynamicResource Report-Title}"
    Width="1000"
    Height="600"
    Background="{DynamicResource MaterialDesignPaper}"
    FontFamily="{StaticResource MaterialDesignFont}"
    Icon="/Image/favicon.ico"
    ResizeMode="CanResizeWithGrip"
    TextElement.FontSize="13"
    TextElement.FontWeight="Regular"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto"
    WindowStartupLocation="CenterScreen">  

        <!-- ReportTbl81ImagesWindow.xaml  Skriptdatum:  12.07.2018  10:32   -->    
          
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
	<ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Button.xaml" />
	<ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Shadows.xaml" />
	 <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.TextBox.xaml" />
	 <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.CheckBox.xaml" />
            </ResourceDictionary.MergedDictionaries>
                    <Style BasedOn="{StaticResource MaterialDesignTextBox}" TargetType="{x:Type TextBox}">
                        <Setter Property="Margin" Value="2,0,2,0" />
                    </Style>
                    <Style BasedOn="{StaticResource MaterialDesignListBox}" TargetType="{x:Type ListBox}">
                        <Setter Property="Margin" Value="2,0,2,0" />
                        <Setter Property="Height" Value="24" />
                    </Style>
                    <Style TargetType="{x:Type TableCell}">
                        <Setter Property="Padding" Value="2" />
	    </Style>
                </ResourceDictionary>
            </Window.Resources>          
             
    <Grid x:Name="LayoutRoot">
        <Grid.Resources>
            <converters:DateConverter x:Key="DateConverter" />
            <converters:TimeConverter x:Key="TimeConverter" />
            <converters:BooleanToVisibilityConverter
                x:Key="BooleanToVisibilityConverter"
                False="Collapsed"
                True="Visible" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions> 
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            DockPanel.Dock="Top"
            Orientation="Horizontal">
            <TextBox
                x:Name="Reader"
                Margin="10,0,10,0"
                materialDesign:HintAssist.Hint="{DynamicResource ReportFlow-PaperWidth}"
                LostFocus="Reader_LostFocus"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                Text="1000" />
            <TextBox
                x:Name="PageWidthText"
                Margin="10,0,10,0"
                materialDesign:HintAssist.Hint="{DynamicResource ReportFlow-PageWidth}"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                Text="1000" />
            <TextBox
                x:Name="PagePaddingText"
                Margin="10,0,10,0"
                materialDesign:HintAssist.Hint="{DynamicResource ReportFlow-PagePadding}"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                Text="28" />
            <TextBox
                x:Name="ColumnWidthText"
                Margin="10,0,10,0"
                materialDesign:HintAssist.Hint="{DynamicResource ReportFlow-ColumnWidth}"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                Text="800" />
            <CheckBox
                x:Name="FlexibleChecked"
                VerticalAlignment="Center"
                Content="{DynamicResource ReportFlow-ColumnWidthFlex}"
                IsChecked="True"
                Style="{StaticResource MaterialDesignCheckBox}" />
            <Button
                Width="100"
                Margin="200,5,100,5"
                VerticalAlignment="Center"
                materialDesign:ShadowAssist.ShadowDepth="Depth1"
                Click="Print_Click"
                Content="{DynamicResource Shared-ButtonPrint}"
                Style="{StaticResource MaterialDesignFlatButton}" />
            <Button
                Width="100"
                Margin="20,5,10,5"
                VerticalAlignment="Center"
                materialDesign:ShadowAssist.ShadowDepth="Depth1"
                Command="{Binding PdfTbl81ImagesCommand}"
                Content="PDF"
                Style="{StaticResource MaterialDesignFlatButton}" />
        </StackPanel>        

                
   <!--   Part 1  -->     
                                                                                                                                                
             
        <FlowDocumentReader
            Grid.Row="1"
            Width="{Binding ElementName=ReaderWidthText, Path=Text, UpdateSourceTrigger=LostFocus}"
            Margin="5,10"
            BorderBrush="Black"
            BorderThickness="0.5">
            <FlowDocument
                x:Name="FlowDocument"
                Background="White"
                ColumnWidth="{Binding ElementName=ColumnWidthText, Path=Text}"
                FontFamily="Arial"
                FontSize="12"
                IsColumnWidthFlexible="{Binding ElementName=FlexibleChecked, Path=IsChecked}"
                PagePadding="{Binding ElementName=PagePaddingText, Path=Text}"
                PageWidth="{Binding ElementName=PageWidthText, Path=Text}">
                <Section FontSize="14pt">
                    <Paragraph TextAlignment="Left">
                        <TextBlock
                            Width="{Binding ElementName=PageWidthText, Path=Text}"
                            Margin="10,0,0,0"
                            FontWeight="Bold"
                            Style="{StaticResource MaterialDesignHeadlineTextBlock}"
                            Text="{DynamicResource Report-Title}" />
                    </Paragraph>
                </Section>                                                  
             
                <Section>
                    <Paragraph>
                        <materialDesign:Card
                            Width="{Binding ElementName=PageWidthText, Path=Text}"
                            Margin="2,0,0,0"
                            Background="{DynamicResource PrimaryHueLightBrush}"
                            Foreground="{DynamicResource PrimaryHueDarkForegroundBrush}"
                            UniformCornerRadius="2">
                        <ListBox
                            Width="{Binding ElementName=PageWidthText, Path=Text}"
                            Height="Auto"
                            Margin="0"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding Tbl81ImagesList}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <StackPanel Margin="2,0,0,0" Orientation="Horizontal">
                                            <TextBlock
                                                Width="Auto"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="{Binding (models:Tbl81Image.ImageName)}" />            
                                            <TextBlock
                                                Width="Auto"
                                                Margin="2,0,0,0"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="{Binding (models:Tbl81Image.Author)}" />
                                            <TextBlock
                                                Width="Auto"
                                                Margin="2,0,0,0"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="{Binding (models:Tbl81Image.AuthorYear)}" />
                                        </StackPanel>
                                        <StackPanel  Orientation="Horizontal">
                                            <TextBlock Width="Auto" Text="{DynamicResource Report-TaxonomicId}" />
                                            <TextBlock Width="Auto" Text="{Binding (models:Tbl81Image.CountID)}" />            
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                         </ListBox>
                       </materialDesign:Card>
                  </Paragraph>
              </Section>  

             
   <!--   Part 2  -->     
                    
             
