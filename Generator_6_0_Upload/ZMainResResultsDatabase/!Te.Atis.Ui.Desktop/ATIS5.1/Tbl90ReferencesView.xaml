                                                        </StackPanel>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>                                                                                                                           
              
                                            <GridViewColumn
                                                Width="500"
                                                DisplayMemberBinding="{Binding (models:Tbl90Reference.Info)}"
                                                Header="{DynamicResource Shared-Info}" />                                                                                                
             
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
