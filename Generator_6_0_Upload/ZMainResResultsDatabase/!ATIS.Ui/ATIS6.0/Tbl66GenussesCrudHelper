        public void FiSpeciesSave(Tbl69FiSpecies home, Tbl69FiSpecies selected)
        {
            if (selected.GenusId != 0) //update
            {
                _uow.Tbl69FiSpeciesses.Update(home);
            }
            else                                //add
                _uow.Tbl69FiSpeciesses.Add(home);
            _uow.Complete();
        }

