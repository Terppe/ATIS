            if (home != null) //update
            {
                home.FiSpeciesName = selected.FiSpeciesName;
                home.RefAuthorId = selected.RefAuthorId;
                home.Valid = selected.Valid;
                home.ValidYear = selected.ValidYear;
                home.Author = selected.Author;
