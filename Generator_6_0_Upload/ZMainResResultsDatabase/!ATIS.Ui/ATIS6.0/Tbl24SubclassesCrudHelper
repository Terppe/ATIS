        public void InfraclassSave(Tbl27Infraclass home, Tbl27Infraclass selected)
        {
            if (selected.SubclassId != 0) //update
            {
                _uow.Tbl27Infraclasses.Update(home);
            }
            else                                //add
                _uow.Tbl27Infraclasses.Add(home);
            _uow.Complete();
        }

