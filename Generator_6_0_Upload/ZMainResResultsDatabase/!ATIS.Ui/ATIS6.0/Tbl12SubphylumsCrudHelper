        public void SuperclassSave(Tbl18Superclass home, Tbl18Superclass selected)
        {
            if (selected.SubphylumId != 0) //update
            {
                _uow.Tbl18Superclasses.Update(home);
            }
            else                                //add
                _uow.Tbl18Superclasses.Add(home);
            _uow.Complete();
        }

