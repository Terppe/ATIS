        public void SuperfamilySave(Tbl42Superfamily home, Tbl42Superfamily selected)
        {

            if (selected.SuperfamilyId != 0) //update
            {
                _uow.Tbl42Superfamilies.Update(home);
            }
            else                                //add
                _uow.Tbl42Superfamilies.Add(home);
            _uow.Complete();
        }

