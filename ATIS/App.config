  <userSettings>
    <ATIS.Ui.Properties.Settings>
      <setting name="Language" serializeAs="String">
        <value>CSharp</value>
      </setting>
      <setting name="ServerName" serializeAs="String">
        <value>.\SQLEXPRESS</value>
      </setting>
      <setting name="WindowState" serializeAs="String">
        <value>Normal</value>
      </setting>
      <setting name="Theme1" serializeAs="String">
        <value>Light</value>
      </setting>
      <setting name="Accent1" serializeAs="String">
        <value>Cyan</value>
      </setting>
      <setting name="Primary1" serializeAs="String">
        <value>Teal</value>
      </setting>
      <setting name="Culture" serializeAs="String">
        <value>de-DE</value>
      </setting>
      <setting name="ApplicationName" serializeAs="String">
        <value>ATIS</value>
      </setting>
      <setting name="RemoteTestTimeout" serializeAs="String">
        <value>700</value>
      </setting>
      <setting name="Database" serializeAs="String">
        <value>ATIS35</value>
      </setting>
      <setting name="GitHub" serializeAs="String">
        <value>https://github.com/</value>
      </setting>
      <setting name="Pdf" serializeAs="String">
        <value>5LX7Z-5GUF6-UUYTR-8YOQC-XGT2B</value>
      </setting>
    </ATIS.Ui.Properties.Settings>
  </userSettings>
</configuration>