                                            <TextBlock>
                                                <Hyperlink Click="HyperlinkSubphylum_Click" Tag="{Binding (models:Tbl12Subphylum.SubphylumId)}">
                                                    <TextBlock Text="{Binding (models:Tbl12Subphylum.SubphylumName)}" />
                                                </Hyperlink>
                                            </TextBlock>
                                            <TextBlock Width="Auto" Margin="2,0,0,0">
                                                <TextBlock.Text>
