<mah:MetroWindow
    x:Class="ATIS.Ui.Views.Report.D69FiSpecies.ReportFiSpeciesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:models="clr-namespace:ATIS.Ui.Models"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:valueConverter="clr-namespace:ATIS.Ui.Helper.ValueConverter"
    Title="{DynamicResource Report-Title}"
    Width="1250"
    Height="600"
    ResizeMode="CanResizeWithGrip">

    <!--  ReportFiSpeciesWindow.xaml  Skriptdatum:  07.01.2021  10:32  -->

    <mah:MetroWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <valueConverter:ImageSourceConverter x:Key="ImageSourceConverter" />
            <Style BasedOn="{StaticResource MahApps.Styles.TextBox}" TargetType="{x:Type TextBox}">
                <Setter Property="Margin" Value="2,0,2,0" />
            </Style>
            <Style BasedOn="{StaticResource MahApps.Styles.ListBox}" TargetType="{x:Type ListBox}">
                <Setter Property="Margin" Value="2,0,2,0" />
                <Setter Property="Height" Value="24" />
            </Style>
            <Style TargetType="{x:Type TableCell}">
                <Setter Property="Padding" Value="2" />
            </Style>
        </ResourceDictionary>
    </mah:MetroWindow.Resources>

    <Grid x:Name="LayoutRoot">
        <Grid.Resources>
            <valueConverter:AuthorConverter x:Key="AuthorConverter" />
            <valueConverter:AuthorWithoutStringConverter x:Key="AuthorWithoutStringConverter" />
            <valueConverter:NameConverter x:Key="NameConverter" />
            <valueConverter:DateConverter x:Key="DateConverter" />
            <valueConverter:TimeConverter x:Key="TimeConverter" />
            <valueConverter:BooleanToVisibilityConverter
                x:Key="BooleanToVisibilityConverter"
                False="Collapsed"
                True="Visible" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            DockPanel.Dock="Top"
            Orientation="Horizontal">
            <TextBox
                x:Name="Reader"
                Margin="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                mah:TextBoxHelper.IsWaitingForData="True"
                mah:TextBoxHelper.UseFloatingWatermark="True"
                mah:TextBoxHelper.Watermark="Reader"
                mah:TextBoxHelper.WatermarkAlignment="Left"
                FontWeight="Medium"
                LostFocus="Reader_LostFocus"
                SpellCheck.IsEnabled="True"
                Text="1050"
                ToolTip="Reader" />

            <TextBox
                x:Name="PageWidthText"
                Margin="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                mah:TextBoxHelper.IsWaitingForData="True"
                mah:TextBoxHelper.UseFloatingWatermark="True"
                mah:TextBoxHelper.Watermark="PageWidthText"
                mah:TextBoxHelper.WatermarkAlignment="Left"
                FontWeight="Medium"
                SpellCheck.IsEnabled="True"
                Text="1200"
                ToolTip="PageWidthText" />

            <TextBox
                x:Name="PagePaddingText"
                Margin="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                mah:TextBoxHelper.IsWaitingForData="True"
                mah:TextBoxHelper.UseFloatingWatermark="True"
                mah:TextBoxHelper.Watermark="PagePaddingText"
                mah:TextBoxHelper.WatermarkAlignment="Left"
                FontWeight="Medium"
                SpellCheck.IsEnabled="True"
                Text="28"
                ToolTip="PagePaddingText" />

            <TextBox
                x:Name="ColumnWidthText"
                Margin="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                mah:TextBoxHelper.IsWaitingForData="True"
                mah:TextBoxHelper.UseFloatingWatermark="True"
                mah:TextBoxHelper.Watermark="ColumnWidthText"
                mah:TextBoxHelper.WatermarkAlignment="Left"
                FontWeight="Medium"
                SpellCheck.IsEnabled="True"
                Text="800"
                ToolTip="ColumnWidthText" />

            <CheckBox
                x:Name="FlexibleChecked"
                VerticalAlignment="Center"
                Content="{DynamicResource ReportFlow-ColumnWidthFlex}"
                IsChecked="True"
                Style="{StaticResource MahApps.Styles.CheckBox}" />
            <Button
                Width="100"
                Margin="100,5,10,5"
                VerticalAlignment="Center"
                Click="Print_Click"
                Content="{DynamicResource Shared-ButtonPrint}"
                Style="{StaticResource MahApps.Styles.Button}" />
            <Button
                Width="120"
                Margin="5,5,10,5"
                VerticalAlignment="Center"
                Command="{Binding PdfFiSpeciesPrintCommand}"
                Content="{DynamicResource Report-PrintPdf}"
                Style="{StaticResource MahApps.Styles.Button}" />
            <Button
                Width="120"
                Margin="5,5,10,5"
                VerticalAlignment="Center"
                Command="{Binding PdfFiSpeciesSaveCommand}"
                Content="{DynamicResource Report-SavePdf}"
                Style="{StaticResource MahApps.Styles.Button}" />
        </StackPanel>


        <!--  Part 1  -->


        <FlowDocumentReader
            Grid.Row="1"
            Width="{Binding ElementName=ReaderWidthText, Path=Text, UpdateSourceTrigger=LostFocus}"
            Margin="5,10"
            BorderBrush="Black"
            BorderThickness="0.5"
            IsPageViewEnabled="False"
            IsPrintEnabled="True"
            IsTwoPageViewEnabled="False"
            ViewingMode="Scroll"
            Zoom="100">
            <FlowDocument
                x:Name="FlowDocument"
                Background="White"
                ColumnWidth="{Binding ElementName=ColumnWidthText, Path=Text}"
                FontFamily="Arial"
                FontSize="12"
                IsColumnWidthFlexible="{Binding ElementName=FlexibleChecked, Path=IsChecked}"
                PagePadding="{Binding ElementName=PagePaddingText, Path=Text}"
                PageWidth="{Binding ElementName=PageWidthText, Path=Text}">
                <Section FontSize="14pt">
                    <Paragraph TextAlignment="Left">
                        <TextBlock
                            Width="{Binding ElementName=PageWidthText, Path=Text}"
                            Margin="10,0,0,0"
                            FontWeight="Bold"
                            Text="{DynamicResource Report-Title}" />
                    </Paragraph>
                </Section>

                <Section>
                    <Paragraph>
                        <GroupBox>
                            <ListBox
                                Width="{Binding ElementName=PageWidthText, Path=Text}"
                                Height="Auto"
                                Margin="0"
                                HorizontalAlignment="Left"
                                ItemsSource="{Binding FiSpeciessesCollection}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <StackPanel Margin="2,0,0,0" Orientation="Horizontal">
                                                <TextBlock
                                                    Width="Auto"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Text="{Binding (models:Tbl69FiSpecies.Tbl66Genusses).GenusName}" />
                                                <TextBlock
                                                    Width="Auto"
                                                    Margin="2,0,0,0"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Text="{Binding (models:Tbl69FiSpecies.FiSpeciesName)}" />
                                                <!--<TextBlock
                                                    Width="Auto"
                                                    Margin="2,0,0,0"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Text="{Binding (models:Tbl69FiSpecies.Subspecies)}" />-->
                                                <!--<TextBlock
                                                    Width="Auto"
                                                    Margin="2,0,0,0"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Text="{Binding (models:Tbl69FiSpecies.Divers)}" />-->
                                                <TextBlock
                                                    Width="Auto"
                                                    Margin="2,0,0,0"
                                                    FontSize="18"
                                                    FontWeight="Bold">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource AuthorWithoutStringConverter}">
                                                            <Binding Path="Author" />
                                                            <Binding Path="AuthorYear" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Width="Auto" Text="{DynamicResource Report-TaxonomicId}" />
                                                <TextBlock Width="Auto" Text="{Binding (models:Tbl69FiSpecies.CountId)}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </GroupBox>
                    </Paragraph>
                </Section>


                <!--  Part 2  -->


                <Section>
                    <Paragraph>
                        <TextBlock
                            Width="{Binding ElementName=PageWidthText, Path=Text}"
                            Margin="2,0,0,0"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="{DynamicResource ValidationErrorBrush}"
                            Text="{DynamicResource Report-TaxoNomen}" />
                    </Paragraph>
                    <Paragraph>
                        <GroupBox>
                            <StackPanel>
                                <ListBox
                                    x:Name="Tbl03Regnums1List"
                                    Width="{Binding ElementName=PageWidthText, Path=Text}"
                                    Height="Auto"
                                    Margin="0"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding RegnumsCollection}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                <TextBlock Width="300" Text="{DynamicResource Tbl03Regnum-Regnum}" />
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat=" {0} {1} ">
                                                            <Binding Path="(models:Tbl03Regnum.RegnumName)" />
                                                            <Binding Path="(models:Tbl03Regnum.Subregnum)" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <ListBox
                                    Width="{Binding ElementName=PageWidthText, Path=Text}"
                                    Height="Auto"
                                    Margin="0"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding FiSpeciessesCollection}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                    <TextBlock
                                                        Width="300"
                                                        FontWeight="Bold"
                                                        Text="{DynamicResource Report-TaxoRank}" />
                                                    <TextBlock Width="130" Text="{DynamicResource Tbl69FiSpecies-FiSpecies}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock
                                    Width="{Binding ElementName=PageWidthText, Path=Text}"
                                    Margin="30,0,0,0"
                                    Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"
                                    Text="{DynamicResource Report-Synonyms}" />
                                <ListBox
                                    Width="{Binding ElementName=PageWidthText, Path=Text}"
                                    Height="Auto"
                                    Margin="0"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding SynonymsCollection}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <StackPanel Margin="320,0,0,0" Orientation="Horizontal">
                                                    <TextBlock Width="auto" Text="{Binding (models:Tbl84Synonym.SynonymName)}" />
                                                    <TextBlock
                                                        Width="Auto"
                                                        Margin="2,0,0,0"
                                                        Text="{Binding (models:Tbl84Synonym.Author)}" />
                                                    <TextBlock
                                                        Width="Auto"
                                                        Margin="2,0,0,0"
                                                        Text="{Binding (models:Tbl84Synonym.AuthorYear)}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock
                                    Width="{Binding ElementName=PageWidthText, Path=Text}"
                                    Margin="30,0,0,0"
                                    Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"
                                    Text="{DynamicResource Report-CommonNames}" />
                                <ListBox
                                    Width="{Binding ElementName=PageWidthText, Path=Text}"
                                    Height="Auto"
                                    Margin="0"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding NamesCollection}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <StackPanel Margin="320,0,0,0" Orientation="Horizontal">
                                                    <TextBlock
                                                        Width="Auto"
                                                        Margin="2,0,0,0"
                                                        Text="{Binding (models:Tbl78Name.NameName)}" />
                                                    <TextBlock
                                                        Width="Auto"
                                                        Margin="2,0,0,0"
                                                        Text="[" />
                                                    <TextBlock Width="auto" Text="{Binding (models:Tbl78Name.Language)}" />
                                                    <TextBlock Width="auto" Text="]" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <ListBox
                                    Width="{Binding ElementName=PageWidthText, Path=Text}"
                                    Height="Auto"
                                    Margin="0"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{Binding FiSpeciessesCollection}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <StackPanel Margin="20,10,0,0" Orientation="Horizontal">
                                                    <TextBlock
                                                        Width="300"
                                                        FontWeight="Bold"
                                                        Text="{DynamicResource Report-TaxoStatus}" />
                                                </StackPanel>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                    <TextBlock Width="300" Text="{DynamicResource Report-CurrentStand}" />
                                                    <CheckBox
                                                        Margin="4,0,0,0"
                                                        VerticalAlignment="Center"
                                                        IsChecked="{Binding (models:Tbl69FiSpecies.Valid)}"
                                                        Style="{StaticResource MahApps.Styles.CheckBox}" />
                                                    <TextBlock
                                                        Width="100"
                                                        Margin="2,0,0,0"
                                                        Text="{Binding (models:Tbl69FiSpecies.Valid)}" />
                                                    <TextBlock
                                                        Width="100"
                                                        Margin="2,0,0,0"
                                                        Text="{Binding (models:Tbl69FiSpecies.ValidYear)}" />
                                                </StackPanel>
                                                <StackPanel Margin="20,20,0,0" Orientation="Horizontal">
                                                    <TextBlock
                                                        Width="300"
                                                        FontWeight="Bold"
                                                        Text="{DynamicResource Report-DataQualiIndicator}" />
                                                </StackPanel>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                    <TextBlock Width="300" Text="{DynamicResource Report-RecordCrediRate}" />
                                                </StackPanel>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                    <StackPanel.Resources>
                                                        <valueConverter:DateTimeConverter x:Key="DateTimeConverter" />
                                                    </StackPanel.Resources>
                                                    <TextBlock Width="300" Text="{DynamicResource Report-RecordUpdate}" />
                                                    <TextBlock Width="300">
                                                        <TextBlock Text="{Binding (models:Tbl69FiSpecies.UpdaterDate), Converter={StaticResource DateTimeConverter}}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                    <TextBlock Width="300" Text="{DynamicResource Tbl69FiSpecies-TradeName}" />
                                                    <TextBlock Width="Auto" Text="{Binding (models:Tbl69FiSpecies.TradeName)}" />
                                                </StackPanel>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                    <TextBlock Width="300" Text="{DynamicResource Tbl69FiSpecies-MemoSpecies}" />
                                                    <TextBlock
                                                        Width="Auto"
                                                        Text="{Binding (models:Tbl69FiSpecies.MemoSpecies)}"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                    <TextBlock Width="300" Text="{DynamicResource Tbl69FiSpecies-Importer}" />
                                                    <TextBlock Width="Auto" Text="{Binding (models:Tbl69FiSpecies.Importer)}" />
                                                    <TextBlock
                                                        Width="Auto"
                                                        Margin="2,0,0,0"
                                                        Text="{Binding (models:Tbl69FiSpecies.ImportingYear)}" />
                                                </StackPanel>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                    <TextBlock Width="300" Text="{DynamicResource Tbl69FiSpecies-LNumberLOrigin}" />
                                                    <TextBlock Width="Auto" Text="{Binding (models:Tbl69FiSpecies.LNumber)}" />
                                                    <TextBlock
                                                        Width="Auto"
                                                        Margin="2,0,0,0"
                                                        Text="{Binding (models:Tbl69FiSpecies.LOrigin)}" />
                                                </StackPanel>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                    <TextBlock Width="300" Text="{DynamicResource Tbl69FiSpecies-LdaNumberLdaOrigin}" />
                                                    <TextBlock Width="Auto" Text="{Binding (models:Tbl69FiSpecies.LdaNumber)}" />
                                                    <TextBlock
                                                        Width="Auto"
                                                        Margin="2,0,0,0"
                                                        Text="{Binding (models:Tbl69FiSpecies.LdaOrigin)}" />
                                                </StackPanel>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                    <TextBlock Width="300" Text="{DynamicResource Tbl69FiSpecies-BasinLength}" />
                                                    <TextBlock Width="Auto" Text="{Binding (models:Tbl69FiSpecies.BasinLength)}" />
                                                </StackPanel>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                    <TextBlock Width="300" Text="{DynamicResource Tbl69FiSpecies-FishLength}" />
                                                    <TextBlock Width="Auto" Text="{Binding (models:Tbl69FiSpecies.FishLength)}" />
                                                </StackPanel>
                                                <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                                    <TextBlock Width="300" Text="{DynamicResource Shared-Memo}" />
                                                    <TextBlock
                                                        Width="500"
                                                        Text="{Binding (models:Tbl69FiSpecies.MemoSpecies)}"
                                                        TextWrapping="Wrap" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                            </StackPanel>
                        </GroupBox>
                    </Paragraph>



                    <!--  Part 3  -->


                    <Paragraph>
                        <!--  Tbl03Regnums  -->
                        <TextBlock
                            Width="{Binding ElementName=PageWidthText, Path=Text}"
                            Margin="2,0,0,10"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="{DynamicResource ValidationErrorBrush}"
                            Text="{DynamicResource Report-TaxoHiera}" />
                        <StackPanel>
                            <ListBox
                                x:Name="Tbl03RegnumsList"
                                Width="{Binding ElementName=PageWidthText, Path=Text}"
                                Height="Auto"
                                Margin="0"
                                HorizontalAlignment="Left"
                                ItemsSource="{Binding RegnumsCollection}"
                                Visibility="{Binding ElementName=Tbl03RegnumsList, Path=HasItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="20,0,0,0" Orientation="Horizontal">
                                            <TextBlock Width="300" Text="{DynamicResource Tbl03Regnum-Regnum}" />
                                            <TextBlock>
                                                <Hyperlink Click="HyperlinkRegnum_Click" Tag="{Binding (models:Tbl03Regnum.RegnumId)}">
                                                    <TextBlock>
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat=" {0} {1} ">
                                                                <Binding Path="(models:Tbl03Regnum.RegnumName)" />
                                                                <Binding Path="(models:Tbl03Regnum.Subregnum)" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Hyperlink>
                                            </TextBlock>
                                            <TextBlock Width="Auto" Margin="2,0,0,0">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource AuthorConverter}">
                                                        <Binding Path="Author" />
                                                        <Binding Path="AuthorYear" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Width="Auto" Margin="2,0,0,0">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource NameConverter}">
                                                        <Binding Path="GerName" />
                                                        <Binding Path="EngName" />
                                                        <Binding Path="FraName" />
                                                        <Binding Path="PorName" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <!--  Tbl06Phylums  -->

                        <StackPanel>
                            <ListBox
