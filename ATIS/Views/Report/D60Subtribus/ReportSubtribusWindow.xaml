<mah:MetroWindow
    x:Class="ATIS.Ui.Views.Report.D60Subtribus.ReportSubtribusWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:models="clr-namespace:ATIS.Ui.Models"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:valueConverter="clr-namespace:ATIS.Ui.Helper.ValueConverter"
    Title="{DynamicResource Report-Title}"
    Width="1250"
    Height="600"
    ResizeMode="CanResizeWithGrip">

    <!-- ReportSubtribusWindow.xaml  Skriptdatum:  07.01.2021  10:32   -->

    <mah:MetroWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style BasedOn="{StaticResource MahApps.Styles.TextBox}" TargetType="{x:Type TextBox}">
                <Setter Property="Margin" Value="2,0,2,0" />
            </Style>
            <Style BasedOn="{StaticResource MahApps.Styles.ListBox}" TargetType="{x:Type ListBox}">
                <Setter Property="Margin" Value="2,0,2,0" />
                <Setter Property="Height" Value="24" />
            </Style>
            <Style TargetType="{x:Type TableCell}">
                <Setter Property="Padding" Value="2" />
            </Style>
        </ResourceDictionary>
    </mah:MetroWindow.Resources>

    <Grid x:Name="LayoutRoot">
        <Grid.Resources>
            <valueConverter:AuthorConverter x:Key="AuthorConverter" />
            <valueConverter:AuthorWithoutStringConverter x:Key="AuthorWithoutStringConverter" />
            <valueConverter:NameConverter x:Key="NameConverter" />
            <valueConverter:DateConverter x:Key="DateConverter" />
            <valueConverter:TimeConverter x:Key="TimeConverter" />
            <valueConverter:BooleanToVisibilityConverter
                x:Key="BooleanToVisibilityConverter"
                False="Collapsed"
                True="Visible" />
        </Grid.Resources>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            DockPanel.Dock="Top"
            Orientation="Horizontal">
            <TextBox
                x:Name="Reader"
                Margin="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                mah:TextBoxHelper.IsWaitingForData="True"
                mah:TextBoxHelper.UseFloatingWatermark="True"
                mah:TextBoxHelper.Watermark="Reader"
                mah:TextBoxHelper.WatermarkAlignment="Left"
                FontWeight="Medium"
                LostFocus="Reader_LostFocus"
                SpellCheck.IsEnabled="True"
                Text="1050"
                ToolTip="Reader" />

            <TextBox
                x:Name="PageWidthText"
                Margin="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                mah:TextBoxHelper.IsWaitingForData="True"
                mah:TextBoxHelper.UseFloatingWatermark="True"
                mah:TextBoxHelper.Watermark="PageWidthText"
                mah:TextBoxHelper.WatermarkAlignment="Left"
                FontWeight="Medium"
                SpellCheck.IsEnabled="True"
                Text="1200"
                ToolTip="PageWidthText" />

            <TextBox
                x:Name="PagePaddingText"
                Margin="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                mah:TextBoxHelper.IsWaitingForData="True"
                mah:TextBoxHelper.UseFloatingWatermark="True"
                mah:TextBoxHelper.Watermark="PagePaddingText"
                mah:TextBoxHelper.WatermarkAlignment="Left"
                FontWeight="Medium"
                SpellCheck.IsEnabled="True"
                Text="28"
                ToolTip="PagePaddingText" />

            <TextBox
                x:Name="ColumnWidthText"
                Margin="10,0,10,0"
                HorizontalContentAlignment="Stretch"
                mah:TextBoxHelper.IsWaitingForData="True"
                mah:TextBoxHelper.UseFloatingWatermark="True"
                mah:TextBoxHelper.Watermark="ColumnWidthText"
                mah:TextBoxHelper.WatermarkAlignment="Left"
                FontWeight="Medium"
                SpellCheck.IsEnabled="True"
                Text="800"
                ToolTip="ColumnWidthText" />

            <CheckBox
                x:Name="FlexibleChecked"
                VerticalAlignment="Center"
                Content="{DynamicResource ReportFlow-ColumnWidthFlex}"
                IsChecked="True"
                Style="{StaticResource MahApps.Styles.CheckBox}" />
            <Button
                Width="100"
                Margin="100,5,10,5"
                VerticalAlignment="Center"
                Click="Print_Click"
                Content="{DynamicResource Shared-ButtonPrint}"
                Style="{StaticResource MahApps.Styles.Button}" />
            <Button
                Width="120"
                Margin="5,5,10,5"
                VerticalAlignment="Center"
                Command="{Binding PdfSubtribusPrintCommand}"
                Content="{DynamicResource Report-PrintPdf}"
                Style="{StaticResource MahApps.Styles.Button}" />
            <Button
                Width="120"
                Margin="5,5,10,5"
                VerticalAlignment="Center"
                Command="{Binding PdfSubtribusSaveCommand}"
                Content="{DynamicResource Report-SavePdf}"
                Style="{StaticResource MahApps.Styles.Button}" />
        </StackPanel>


        <!--   Part 1  -->


        <FlowDocumentReader
            Grid.Row="1"
            Width="{Binding ElementName=ReaderWidthText, Path=Text, UpdateSourceTrigger=LostFocus}"
            Margin="5,10"
            BorderBrush="Black"
            BorderThickness="0.5"
            IsPageViewEnabled="False"
            IsPrintEnabled="True"
            IsTwoPageViewEnabled="False"
            ViewingMode="Scroll"
            Zoom="100">
            <FlowDocument
                x:Name="FlowDocument"
                Background="White"
                ColumnWidth="{Binding ElementName=ColumnWidthText, Path=Text}"
                FontFamily="Arial"
                FontSize="12"
                IsColumnWidthFlexible="{Binding ElementName=FlexibleChecked, Path=IsChecked}"
                PagePadding="{Binding ElementName=PagePaddingText, Path=Text}"
                PageWidth="{Binding ElementName=PageWidthText, Path=Text}">
                <Section FontSize="14pt">
                    <Paragraph TextAlignment="Left">
                        <TextBlock
                            Width="{Binding ElementName=PageWidthText, Path=Text}"
                            Margin="10,0,0,0"
                            FontWeight="Bold"
                            Text="{DynamicResource Report-Title}" />
                    </Paragraph>
                </Section>

                <Section>
                    <Paragraph>
                        <GroupBox>
                            <ListBox
                            Width="{Binding ElementName=PageWidthText, Path=Text}"
                            Height="Auto"
                            Margin="0"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding SubtribussesCollection}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <StackPanel Margin="2,0,0,0" Orientation="Horizontal">
                                                <TextBlock
                                                Width="Auto"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="{Binding (models:Tbl60Subtribus.SubtribusName)}" />
                                                <TextBlock
                                                    Width="Auto"
                                                    Margin="2,0,0,0"
                                                    FontSize="18"
                                                    FontWeight="Bold">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource AuthorWithoutStringConverter}">
                                                            <Binding Path="(models:Tbl60Subtribus.Author)" />
                                                            <Binding Path="(models:Tbl60Subtribus.AuthorYear)" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel  Orientation="Horizontal">
                                                <TextBlock Width="Auto" Text="{DynamicResource Report-TaxonomicId}" />
                                                <TextBlock Width="Auto" Text="{Binding (models:Tbl60Subtribus.CountId)}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </GroupBox>
                    </Paragraph>
                </Section>


                <!--   Part 2  -->


                <Section>
                    <Paragraph>
                        <TextBlock
                            Width="{Binding ElementName=PageWidthText, Path=Text}"
                            Margin="2,0,0,0"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="{DynamicResource ValidationErrorBrush}"
                            Text="{DynamicResource Report-TaxoNomen}" />
                    </Paragraph>
                    <Paragraph>
                        <StackPanel>
                            <ListBox
                                x:Name="Tbl03Regnums1List"
                                Width="{Binding ElementName=PageWidthText, Path=Text}"
                                Height="Auto"
                                Margin="0"
                                HorizontalAlignment="Left"
