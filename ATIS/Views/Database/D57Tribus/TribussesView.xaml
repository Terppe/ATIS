                                            ElementName="Tbl93CommentsList"
                                            Mode="TwoWay"
                                            Path="SelectedItem.(models:Tbl93Comment.Memo)"
                                            UpdateSourceTrigger="PropertyChanged" />
                                    </TextBox.Text>
                                </TextBox>
                            </ScrollViewer>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </TabItem>

        </TabControl>

        <StackPanel
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="3" />

    </Grid>
</UserControl>

