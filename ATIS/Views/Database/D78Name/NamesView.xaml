                        </StackPanel>
                        <StackPanel Height="Auto" Orientation="Horizontal">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBox
                                    Height="Auto"
                                    MinWidth="700"
                                    MinHeight="75"
                                    MaxWidth="700"
