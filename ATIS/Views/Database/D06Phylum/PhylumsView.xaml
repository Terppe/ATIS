                                                    <TextBox Width="760" Margin="5,0,0,0">
                                                        <TextBox.Text>
                                                            <Binding
                                                                ElementName="Tbl90ReferenceAuthorsList"
                                                                Mode="TwoWay"
                                                                Path="SelectedItem.(models:Tbl90Reference.Info)"
                                                                UpdateSourceTrigger="PropertyChanged" />
                                                        </TextBox.Text>
                                                    </TextBox>
                                                </StackPanel>

                                                <StackPanel Height="Auto" Orientation="Horizontal">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                        <TextBox
                                                            Height="Auto"
                                                            MinWidth="760"
                                                            MinHeight="100"
                                                            MaxWidth="760"
                                                            MaxHeight="400"
                                                            Margin="5,0,0,5"
                                                            VerticalAlignment="Stretch"
                                                            AcceptsReturn="True"
                                                            Style="{StaticResource MahApps.Styles.TextBox}"
                                                            Text="{Binding SelectedItem.(models:Tbl90Reference.Memo), ElementName=Tbl90ReferenceAuthorsList}"
                                                            TextWrapping="Wrap"
                                                            VerticalScrollBarVisibility="Auto" />
                                                    </ScrollViewer>
                                                </StackPanel>
                                            </StackPanel>
                                        </GroupBox>
                                    </TabItem>
                                </TabControl>
                            </GroupBox>
                        </TabItem>

                        <!--  Part 14  -->

                        <TabItem FontWeight="Medium" Header="{DynamicResource Tbl93Comment-Comment}">
                            <GroupBox>
                                <StackPanel Margin="0,8,5,0">
                                    <StackPanel Height="Auto" Orientation="Horizontal">

                                        <ToggleButton
                                            Width="48"
                                            Height="48"
                                            Margin="4"
                                            Command="{Binding SaveCommentCommand}"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Style="{DynamicResource MahApps.Styles.ToggleButton.Circle}">
                                            <ToggleButton.ContentTemplate>
                                                <DataTemplate>
                                                    <iconPacks:PackIconModern
                                                        Width="20"
                                                        Height="20"
                                                        Kind="Save" />
                                                </DataTemplate>
                                            </ToggleButton.ContentTemplate>
                                        </ToggleButton>


                                        <ToggleButton
                                            Width="48"
                                            Height="48"
                                            Margin="4"
                                            Command="{Binding CopyCommentCommand}"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Style="{DynamicResource MahApps.Styles.ToggleButton.Circle}">
                                            <ToggleButton.ContentTemplate>
                                                <DataTemplate>
                                                    <iconPacks:PackIconModern
                                                        Width="20"
                                                        Height="20"
                                                        Kind="PageCopy" />
                                                </DataTemplate>
                                            </ToggleButton.ContentTemplate>
                                        </ToggleButton>


                                        <ToggleButton
                                            Width="48"
                                            Height="48"
                                            Margin="4"
                                            Command="{Binding AddDivisionCommand}"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Style="{DynamicResource MahApps.Styles.ToggleButton.Circle}">
                                            <ToggleButton.ContentTemplate>
                                                <DataTemplate>
                                                    <iconPacks:PackIconModern
                                                        Width="20"
                                                        Height="20"
                                                        Kind="Add" />
                                                </DataTemplate>
                                            </ToggleButton.ContentTemplate>
                                        </ToggleButton>


                                        <ToggleButton
                                            Width="48"
                                            Height="48"
                                            Margin="4"
                                            Command="{Binding DeleteCommentCommand}"
                                            Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                            Style="{DynamicResource MahApps.Styles.ToggleButton.Circle}">
                                            <ToggleButton.ContentTemplate>
                                                <DataTemplate>
                                                    <iconPacks:PackIconModern
                                                        Width="20"
                                                        Height="20"
                                                        Kind="Delete" />
                                                </DataTemplate>
                                            </ToggleButton.ContentTemplate>
                                        </ToggleButton>

                                    </StackPanel>
                                    <StackPanel Height="Auto" Orientation="Horizontal">
                                        <CheckBox
                                            Width="80"
                                            Margin="5,19,0,0"
                                            VerticalAlignment="Bottom"
                                            Content="{DynamicResource Shared-Valid}"
                                            FontWeight="Normal"
                                            IsChecked="{Binding SelectedItem.(models:Tbl93Comment.Valid), ElementName=Tbl93CommentsList}"
                                            Style="{StaticResource MahApps.Styles.CheckBox}" />
                                    </StackPanel>
                                    <StackPanel Height="Auto" Orientation="Horizontal">
                                        <TextBox Width="760" Margin="5,0,0,0">
                                            <TextBox.Text>
                                                <Binding
                                                    ElementName="Tbl93CommentsList"
                                                    Mode="TwoWay"
                                                    Path="SelectedItem.(models:Tbl93Comment.Info)"
                                                    UpdateSourceTrigger="PropertyChanged" />
                                            </TextBox.Text>
                                        </TextBox>
                                    </StackPanel>

                                    <StackPanel Height="Auto" Orientation="Horizontal">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBox
                                                Height="Auto"
                                                MinWidth="760"
                                                MinHeight="100"
                                                MaxWidth="760"
                                                MaxHeight="620"
                                                Margin="5,0,0,5"
                                                VerticalAlignment="Stretch"
                                                AcceptsReturn="True"
                                                Style="{StaticResource MahApps.Styles.TextBox}"
                                                Text="{Binding SelectedItem.(models:Tbl93Comment.Memo), ElementName=Tbl93CommentsList}"
                                                TextWrapping="Wrap"
                                                VerticalScrollBarVisibility="Auto" />
                                        </ScrollViewer>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                        </TabItem>
                    </TabControl>
                </GroupBox>
            </TabItem>
        </TabControl>


        <StackPanel
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="3" />
    </Grid>
</UserControl>
