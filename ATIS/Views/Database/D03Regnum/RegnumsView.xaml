<UserControl
    x:Class="ATIS.Ui.Views.Database.D03Regnum.RegnumsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:d03Regnum="clr-namespace:ATIS.Ui.Views.Database.D03Regnum"
    xmlns:d06Phylum="clr-namespace:ATIS.Ui.Views.Database.D06Phylum"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ATIS.Dal.Models;assembly=ATIS.Dal"
    xmlns:searchTextBox="clr-namespace:SearchTextBox;assembly=SearchTextBox"
    d:DesignHeight="1100"
    d:DesignWidth="1500"
    mc:Ignorable="d">

    <!--  d:DataContext="{d:DesignInstance d03Regnum:RegnumsViewModel}"  -->

    <UserControl.Resources>
        <CollectionViewSource x:Key="RegnumsAllColl" Source="{Binding RegnumsAllCollection}" />
        <CollectionViewSource x:Key="PhylumsAllColl" Source="{Binding PhylumsAllCollection}" />
        <CollectionViewSource x:Key="DivisionsAllColl" Source="{Binding DivisionsAllCollection}" />

        <CollectionViewSource x:Key="ExpertsColl" Source="{Binding ExpertsCollection}" />
        <CollectionViewSource x:Key="SourcesColl" Source="{Binding SourcesCollection}" />
        <CollectionViewSource x:Key="AuthorsColl" Source="{Binding AuthorsCollection}" />

        <DataTemplate x:Key="CompanyDisplayTemplate" DataType="DataGrid">
            <TextBlock Text="{Binding (models:Tbl03Regnum.RegnumName)}" />
        </DataTemplate>
        <DataTemplate x:Key="CompanyEditingTemplate" DataType="DataGrid">
            <ComboBox ItemsSource="{Binding Source={StaticResource RegnumsAllColl}}" SelectedItem="{Binding (models:Tbl03Regnum.RegnumName)}" />
        </DataTemplate>

    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Visible">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="2*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <StackPanel
                            VerticalAlignment="Center"
                            FocusManager.FocusedElement="{Binding ElementName=TbSearchRegnum}"
                            Orientation="Horizontal">
                            <searchTextBox:SearchTextBox
                                x:Name="TbSearchRegnum"
                                Width="200"
                                Height="30"
                                Margin="20,2,30,2"
                                AllowEmptySearches="True"
                                BorderBrush="LightBlue"
                                BorderThickness="1"
                                Command="{Binding GetRegnumsByNameOrIdCommand}"
                                FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}"
                                SearchMode="Instant"
                                Text="{Binding SearchRegnumName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />

                            <!--<TextBox
                                x:Name="TbSearchRegnum"
                                Width="200"
                                Height="30"
                                Margin="20,2,30,2"
                                mah:TextBoxHelper.ButtonCommand="{Binding GetRegnumsByNameOrIdCommand}"
                                mah:TextBoxHelper.ClearTextButton="False"
                                mah:TextBoxHelper.HasText="True"
                                mah:TextBoxHelper.Watermark="Suche RegnumName or ID"
                                BorderBrush="LightBlue"
                                BorderThickness="1"
                                FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}"
                                IsEnabled="True"
                                Style="{DynamicResource MahApps.Styles.TextBox.Search}"
                                Text="{Binding SearchRegnumName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />-->

                            <!--<TextBox
                                x:Name="TbSearchRegnum"
                                Width="200"
                                Height="40"
                                Margin="20,2,30,2"
                                mah:TextBoxHelper.ButtonCommand="{Binding GetRegnumsByNameOrIdCommand}"
                                mah:TextBoxHelper.ClearTextButton="False"
                                mah:TextBoxHelper.HasText="True"
                                mah:TextBoxHelper.UseFloatingWatermark="True"
                                mah:TextBoxHelper.Watermark="Rechercher. on top"
                                BorderBrush="LightBlue"
                                BorderThickness="1"
                                FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}"
                                IsEnabled="True"
                                Style="{DynamicResource MahApps.Styles.TextBox.Search}"
                                Text="{Binding SearchRegnumName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />-->

                            <Button
                                Command="{Binding AddRegnumCommand}"
                                Content="Add"
                                Style="{StaticResource ButtonDefault}"
                                ToolTip="{DynamicResource Shared-ButtonAdd}" />
                            <Button
                                Command="{Binding CopyRegnumCommand}"
                                Content="Copy"
                                Style="{StaticResource ButtonDefault}"
                                ToolTip="{DynamicResource Shared-ButtonCopy}" />
                            <Button
                                Command="{Binding SaveRegnumCommand}"
                                Content="Save"
                                Style="{StaticResource ButtonDefault}"
                                ToolTip="{DynamicResource Shared-ButtonSave}" />
                            <Button
                                Command="{Binding DeleteRegnumCommand}"
                                Content="Delete"
                                Style="{StaticResource ButtonDefault}"
                                ToolTip="{DynamicResource Shared-ButtonDelete}" />
                        </StackPanel>
                        <GroupBox Width="Auto" Header="{DynamicResource Shared-TabStripHeaderRegnums}">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto">
                                <Grid x:Name="LayoutGridRegnum" MinWidth="300">
                                    <DataGrid
                                        Width="{Binding ElementName=LayoutGridRegnum, Path=ActualWidth}"
                                        Height="400"
                                        MaxHeight="500"
                                        AlternatingRowBackground="LightBlue"
                                        AlternationCount="2"
                                        AutoGenerateColumns="False"
                                        BorderBrush="Gray"
                                        BorderThickness="2"
                                        FrozenColumnCount="3"
                                        GridLinesVisibility="All"
                                        IsReadOnly="False"
                                        IsSynchronizedWithCurrentItem="true"
                                        ItemsSource="{Binding RegnumsCollection, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                        SelectedItem="{Binding SelectedRegnum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <DataGrid.InputBindings>
                                            <KeyBinding Command="{Binding SaveRegnumCommand}" Gesture="Ctrl+Shift+S" />
                                        </DataGrid.InputBindings>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn
                                                Width="Auto"
                                                Binding="{Binding RegnumId}"
                                                Header="{DynamicResource Tbl03Regnum-RegnumId}" />
                                            <DataGridTextColumn
                                                Width="Auto"
                                                Binding="{Binding RegnumName}"
                                                Header="{DynamicResource Tbl03Regnum-RegnumName}" />
                                            <DataGridTextColumn
                                                Width="Auto"
                                                Binding="{Binding Subregnum}"
                                                Header="{DynamicResource Tbl03Regnum-Subregnum}" />
                                            <DataGridCheckBoxColumn
                                                Width="80"
                                                Binding="{Binding Valid}"
                                                Header="{DynamicResource Shared-Valid}" />
                                            <DataGridTextColumn
                                                Width="Auto"
                                                Binding="{Binding ValidYear}"
                                                Header="{DynamicResource Shared-ValidYear}" />
                                            <DataGridTemplateColumn Width="300" Header="{DynamicResource Shared-Synonym}">
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <TextBox
                                                            MaxWidth="290"
                                                            MaxHeight="100"
                                                            Text="{Binding Path=Synonym, Mode=TwoWay}"
                                                            TextAlignment="Left"
                                                            TextWrapping="Wrap"
                                                            VerticalScrollBarVisibility="Visible" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock
                                                            MaxWidth="290"
                                                            MaxHeight="100"
                                                            Text="{Binding Path=Synonym, Mode=OneWay}"
                                                            TextAlignment="Left"
                                                            TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn
                                                Width="Auto"
                                                Binding="{Binding Author}"
                                                Header="{DynamicResource Shared-Author}" />
                                            <DataGridTextColumn
                                                Width="Auto"
                                                Binding="{Binding AuthorYear}"
                                                Header="{DynamicResource Shared-AuthorYear}" />
                                            <DataGridTemplateColumn Width="200" Header="{DynamicResource Shared-Info}">
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <TextBox
                                                            MaxWidth="190"
                                                            MaxHeight="100"
                                                            Text="{Binding Path=Info, Mode=TwoWay}"
                                                            TextAlignment="Left"
                                                            TextWrapping="Wrap"
                                                            VerticalScrollBarVisibility="Visible" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock
                                                            MaxWidth="190"
                                                            MaxHeight="100"
                                                            Text="{Binding Path=Info, Mode=OneWay}"
                                                            TextAlignment="Left"
                                                            TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn
                                                Width="Auto"
                                                Binding="{Binding EngName}"
                                                Header="{DynamicResource Shared-EngName}" />
                                            <DataGridTextColumn
                                                Width="Auto"
                                                Binding="{Binding GerName}"
                                                Header="{DynamicResource Shared-GerName}" />
                                            <DataGridTextColumn
                                                Width="Auto"
                                                Binding="{Binding FraName}"
                                                Header="{DynamicResource Shared-FraName}" />
                                            <DataGridTextColumn
                                                Width="Auto"
                                                Binding="{Binding PorName}"
                                                Header="{DynamicResource Shared-SpaName}" />
                                            <DataGridTemplateColumn Width="500" Header="{DynamicResource Shared-Memo}">
                                                <DataGridTemplateColumn.CellEditingTemplate>
                                                    <DataTemplate>
                                                        <TextBox
                                                            MaxWidth="490"
                                                            MaxHeight="100"
                                                            Text="{Binding Path=Memo, Mode=TwoWay}"
                                                            TextAlignment="Left"
                                                            TextWrapping="Wrap"
                                                            VerticalScrollBarVisibility="Visible" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellEditingTemplate>
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock
                                                            MaxWidth="490"
                                                            MaxHeight="100"
                                                            Text="{Binding Path=Memo, Mode=OneWay}"
                                                            TextAlignment="Left"
                                                            TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </ScrollViewer>
                        </GroupBox>
                    </StackPanel>
                    <StackPanel Grid.Row="2">
                        <TabControl
                            Height="Auto"
                            mah:HeaderedControlHelper.HeaderFontFamily="Segoe UI Semibold"
                            mah:HeaderedControlHelper.HeaderFontSize="18"
                            mah:TabControlHelper.Underlined="TabPanel"
                            Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                            SelectedIndex="{Binding TabIndexDetail, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                            <TabItem FontWeight="DemiBold" Header="{DynamicResource Shared-TabStripHeaderExpert-Source-Author-Comment}">
                                <StackPanel>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                VerticalAlignment="Top"
                                                Orientation="Horizontal">
                                                <searchTextBox:SearchTextBox
                                                    x:Name="TbSearchExpert"
                                                    Width="150"
                                                    Height="30"
                                                    Margin="10,5,30,2"
                                                    AllowEmptySearches="True"
                                                    BorderBrush="LightBlue"
                                                    BorderThickness="1"
                                                    Command="{Binding GetExpertsByNameOrIdCommand}"
                                                    SearchMode="Instant"
                                                    Text="{Binding SearchExpertName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                    ToolTip="{DynamicResource Shared-SearchInfoOrId}" />
                                            </StackPanel>
                                            <StackPanel
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="180,0,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Orientation="Horizontal">
                                                <Button
                                                    Command="{Binding AddExpertCommand}"
                                                    Content="Add"
                                                    Style="{StaticResource ButtonDefault}"
                                                    ToolTip="{DynamicResource Shared-ButtonAdd}" />
                                                <Button
                                                    Command="{Binding CopyExpertCommand}"
                                                    Content="Copy"
                                                    Style="{StaticResource ButtonDefault}"
                                                    ToolTip="{DynamicResource Shared-ButtonCopy}" />
                                                <Button
                                                    Command="{Binding SaveExpertCommand}"
                                                    Content="Save"
                                                    Style="{StaticResource ButtonDefault}"
                                                    ToolTip="{DynamicResource Shared-ButtonSave}" />
                                                <Button
                                                    Command="{Binding DeleteExpertCommand}"
                                                    Content="Delete"
                                                    Style="{StaticResource ButtonDefault}"
                                                    ToolTip="{DynamicResource Shared-ButtonDelete}" />
                                            </StackPanel>
                                            <GroupBox
                                                Grid.Row="1"
                                                Grid.Column="0"
                                                Width="Auto"
                                                Header="{DynamicResource Shared-ReferenceExpert}">
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                                                    <Grid x:Name="LayoutGridRefExpert" MinWidth="300">
                                                        <DataGrid
                                                            Width="{Binding ElementName=LayoutGridRefExpert, Path=ActualWidth}"
                                                            Height="Auto"
                                                            MaxHeight="200"
                                                            AlternatingRowBackground="LightBlue"
                                                            AlternationCount="2"
                                                            AutoGenerateColumns="False"
                                                            BorderBrush="Gray"
                                                            BorderThickness="2"
                                                            FrozenColumnCount="2"
                                                            GridLinesVisibility="All"
                                                            HorizontalScrollBarVisibility="Visible"
                                                            IsReadOnly="False"
                                                            IsSynchronizedWithCurrentItem="true"
                                                            ItemsSource="{Binding ReferenceExpertsCollection, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectedItem="{Binding SelectedReferenceExpert, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            VerticalScrollBarVisibility="Visible">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn
                                                                    Width="Auto"
                                                                    Binding="{Binding ReferenceId}"
                                                                    Header="{DynamicResource Tbl90Reference-ReferenceId}" />
                                                                <DataGridTextColumn
                                                                    Width="Auto"
                                                                    Binding="{Binding RefExpertId}"
                                                                    Header="{DynamicResource Tbl90RefExpert-ExpertId}" />
                                                                <DataGridTemplateColumn Width="Auto" Header="{DynamicResource Tbl90Reference-RefExpertName}">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox
                                                                                Width="Auto"
                                                                                Margin="5,0,0,0"
                                                                                IsSynchronizedWithCurrentItem="False"
                                                                                ItemsSource="{Binding Source={StaticResource ExpertsColl}}"
                                                                                SelectedValue="{Binding (models:Tbl90RefExpert.RefExpertId), UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                                SelectedValuePath="RefExpertId"
                                                                                VirtualizingStackPanel.IsVirtualizing="True">
                                                                                <ComboBox.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <StackPanel Orientation="Horizontal">
                                                                                            <TextBlock Text="{Binding (models:Tbl90RefExpert.RefExpertName)}" />
                                                                                        </StackPanel>
                                                                                    </DataTemplate>
                                                                                </ComboBox.ItemTemplate>
                                                                            </ComboBox>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTextColumn
                                                                    Width="Auto"
                                                                    Binding="{Binding RegnumId}"
                                                                    Header="{DynamicResource Tbl03Regnum-RegnumId}" />
                                                                <DataGridCheckBoxColumn
                                                                    Width="Auto"
                                                                    Binding="{Binding Valid}"
                                                                    Header="{DynamicResource Shared-Valid}" />
                                                                <DataGridTextColumn
                                                                    Width="Auto"
                                                                    Binding="{Binding ValidYear}"
                                                                    Header="{DynamicResource Shared-ValidYear}" />
                                                                <DataGridTemplateColumn Width="500" Header="{DynamicResource Shared-Info}">
                                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                                        <DataTemplate>
                                                                            <TextBox
                                                                                MaxWidth="490"
                                                                                MaxHeight="100"
                                                                                Text="{Binding Path=Info, Mode=TwoWay}"
                                                                                TextAlignment="Left"
                                                                                TextWrapping="Wrap"
                                                                                VerticalScrollBarVisibility="Visible" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock
                                                                                MaxWidth="490"
                                                                                MaxHeight="100"
                                                                                Text="{Binding Path=Info, Mode=OneWay}"
                                                                                TextAlignment="Left"
                                                                                TextWrapping="Wrap" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTemplateColumn Width="600" Header="{DynamicResource Shared-Memo}">
                                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                                        <DataTemplate>
                                                                            <TextBox
                                                                                MaxWidth="590"
                                                                                MaxHeight="100"
                                                                                Text="{Binding Path=Memo, Mode=TwoWay}"
                                                                                TextAlignment="Left"
                                                                                TextWrapping="Wrap"
                                                                                VerticalScrollBarVisibility="Visible" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock
                                                                                MaxWidth="590"
                                                                                MaxHeight="100"
                                                                                Text="{Binding Path=Memo, Mode=OneWay}"
                                                                                TextAlignment="Left"
                                                                                TextWrapping="Wrap" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Grid>
                                                </ScrollViewer>
                                            </GroupBox>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                VerticalAlignment="Top"
                                                Orientation="Horizontal">
                                                <searchTextBox:SearchTextBox
                                                    x:Name="TbSearchSource"
                                                    Width="150"
                                                    Height="30"
                                                    Margin="10,5,30,2"
                                                    AllowEmptySearches="True"
                                                    BorderBrush="LightBlue"
                                                    BorderThickness="1"
                                                    Command="{Binding GetSourcesByNameOrIdCommand}"
                                                    SearchMode="Instant"
                                                    Text="{Binding SearchSourceName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                    ToolTip="{DynamicResource Shared-SearchInfoOrId}" />
                                            </StackPanel>
                                            <StackPanel
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="180,0,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal">
                                                <Button
                                                    Command="{Binding AddSourceCommand}"
                                                    Content="Add"
                                                    Style="{StaticResource ButtonDefault}"
                                                    ToolTip="{DynamicResource Shared-ButtonAdd}" />
                                                <Button
                                                    Command="{Binding CopySourceCommand}"
                                                    Content="Copy"
                                                    Style="{StaticResource ButtonDefault}"
                                                    ToolTip="{DynamicResource Shared-ButtonCopy}" />
                                                <Button
                                                    Command="{Binding SaveSourceCommand}"
                                                    Content="Save"
                                                    Style="{StaticResource ButtonDefault}"
                                                    ToolTip="{DynamicResource Shared-ButtonSave}" />
                                                <Button
                                                    Command="{Binding DeleteSourceCommand}"
                                                    Content="Delete"
                                                    Style="{StaticResource ButtonDefault}"
                                                    ToolTip="{DynamicResource Shared-ButtonDelete}" />
                                            </StackPanel>
                                            <GroupBox
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                Width="Auto"
                                                Header="{DynamicResource Shared-ReferenceSource}">
                                                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                                                    <Grid x:Name="LayoutGridRefSource" MinWidth="300">
                                                        <DataGrid
                                                            Width="{Binding ElementName=LayoutGridRefSource, Path=ActualWidth}"
                                                            Height="Auto"
                                                            MaxHeight="200"
                                                            AlternatingRowBackground="LightBlue"
                                                            AlternationCount="2"
                                                            AutoGenerateColumns="False"
                                                            BorderBrush="Gray"
                                                            BorderThickness="2"
                                                            FrozenColumnCount="2"
                                                            GridLinesVisibility="All"
                                                            HorizontalScrollBarVisibility="Visible"
                                                            IsReadOnly="False"
                                                            IsSynchronizedWithCurrentItem="true"
                                                            ItemsSource="{Binding ReferenceSourcesCollection, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                            SelectedItem="{Binding SelectedReferenceSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            VerticalScrollBarVisibility="Visible">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn
                                                                    Width="Auto"
                                                                    Binding="{Binding ReferenceId}"
                                                                    Header="{DynamicResource Tbl90Reference-ReferenceId}" />
                                                                <DataGridTextColumn
                                                                    Width="Auto"
                                                                    Binding="{Binding RefSourceId}"
                                                                    Header="{DynamicResource Tbl90RefSource-SourceId}" />
                                                                <DataGridTemplateColumn Width="Auto" Header="{DynamicResource Tbl90Reference-RefSourceName}">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox
                                                                                Width="Auto"
                                                                                Margin="5,0,0,0"
                                                                                IsSynchronizedWithCurrentItem="False"
                                                                                ItemsSource="{Binding Source={StaticResource SourcesColl}}"
                                                                                SelectedValue="{Binding (models:Tbl90RefSource.RefSourceId), UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                                SelectedValuePath="RefSourceId"
                                                                                VirtualizingStackPanel.IsVirtualizing="True">
                                                                                <ComboBox.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <StackPanel Orientation="Horizontal">
                                                                                            <TextBlock Text="{Binding (models:Tbl90RefSource.RefSourceName)}" />
                                                                                        </StackPanel>
                                                                                    </DataTemplate>
                                                                                </ComboBox.ItemTemplate>
                                                                            </ComboBox>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTextColumn
                                                                    Width="Auto"
                                                                    Binding="{Binding RegnumId}"
                                                                    Header="{DynamicResource Tbl03Regnum-RegnumId}" />
                                                                <DataGridCheckBoxColumn
                                                                    Width="50"
                                                                    Binding="{Binding Valid}"
                                                                    Header="{DynamicResource Shared-Valid}" />
                                                                <DataGridTextColumn
                                                                    Width="Auto"
                                                                    Binding="{Binding ValidYear}"
                                                                    Header="{DynamicResource Shared-ValidYear}" />
                                                                <DataGridTemplateColumn Width="500" Header="{DynamicResource Shared-Info}">
                                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                                        <DataTemplate>
                                                                            <TextBox
                                                                                MaxWidth="490"
                                                                                MaxHeight="100"
                                                                                Text="{Binding Path=Info, Mode=TwoWay}"
                                                                                TextAlignment="Left"
                                                                                TextWrapping="Wrap"
                                                                                VerticalScrollBarVisibility="Visible" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock
                                                                                MaxWidth="490"
                                                                                MaxHeight="100"
                                                                                Text="{Binding Path=Info, Mode=OneWay}"
                                                                                TextAlignment="Left"
                                                                                TextWrapping="Wrap" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTemplateColumn Width="600" Header="{DynamicResource Shared-Memo}">
                                                                    <DataGridTemplateColumn.CellEditingTemplate>
                                                                        <DataTemplate>
                                                                            <TextBox
                                                                                MaxWidth="590"
                                                                                MaxHeight="100"
                                                                                Text="{Binding Path=Memo, Mode=TwoWay}"
                                                                                TextAlignment="Left"
                                                                                TextWrapping="Wrap"
                                                                                VerticalScrollBarVisibility="Visible" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellEditingTemplate>
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock
                                                                                MaxWidth="590"
                                                                                MaxHeight="100"
                                                                                Text="{Binding Path=Memo, Mode=OneWay}"
                                                                                TextAlignment="Left"
                                                                                TextWrapping="Wrap" />
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Grid>
                                                </ScrollViewer>
                                            </GroupBox>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <StackPanel
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                VerticalAlignment="Top"
                                                Orientation="Horizontal" />
                                            <StackPanel
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                VerticalAlignment="Top"
                                                Orientation="Horizontal">
                                                <searchTextBox:SearchTextBox
                                                    x:Name="TbSearchAuthor"
                                                    Width="150"
                                                    Height="30"
                                                    Margin="10,5,30,2"
                                                    AllowEmptySearches="True"
                                                    BorderBrush="LightBlue"
                                                    BorderThickness="1"
                                                    Command="{Binding GetAuthorsByNameOrIdCommand}"
                                                    SearchMode="Instant"
                                                    Text="{Binding SearchAuthorName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                    ToolTip="{DynamicResource Shared-SearchInfoOrId}" />
                                            </StackPanel>

                                            <StackPanel
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="180,0,0,0"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Orientation="Horizontal">
                                                <Button
                                                    Command="{Binding AddAuthorCommand}"
                                                    Content="Add"
                                                    Style="{StaticResource ButtonDefault}"
                                                    ToolTip="{DynamicResource Shared-ButtonAdd}" />
                                                <Button
                                                    Command="{Binding CopyAuthorCommand}"
