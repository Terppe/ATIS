<UserControl
    x:Class="ATIS.Ui.Views.Database.D03Regnum.RegnumsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:searchTextBox="clr-namespace:SearchTextBox;assembly=SearchTextBox"
    d:DesignHeight="1000"
    d:DesignWidth="1400"
    mc:Ignorable="d">

    <UserControl.Resources>
        <CollectionViewSource x:Key="RegnumsColl" Source="{Binding RegnumsCollection}" />
        <CollectionViewSource x:Key="PhylumsColl" Source="{Binding PhylumsCollection}" />
        <CollectionViewSource x:Key="DivisionsColl" Source="{Binding DivisionsCollection}" />
        <CollectionViewSource x:Key="ExpertsColl" Source="{Binding ExpertsCollection}" />
        <CollectionViewSource x:Key="SourcesColl" Source="{Binding SourcesCollection}" />
        <CollectionViewSource x:Key="AuthorsColl" Source="{Binding AuthorsCollection}" />
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Visible">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="2*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <StackPanel
                            VerticalAlignment="Center"
                            FocusManager.FocusedElement="{Binding ElementName=TbSearchRegnum}"
                            Orientation="Horizontal">
                            <searchTextBox:SearchTextBox
                                x:Name="TbSearchRegnum"
                                Width="200"
                                Height="30"
                                Margin="20,2,30,2"
                                AllowEmptySearches="True"
                                BorderBrush="LightBlue"
                                BorderThickness="1"
                                Command="{Binding GetRegnumsByNameOrIdCommand}"
                                FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}"
                                SearchMode="Instant"
                                Text="{Binding SearchRegnumName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                            <Button
                                Command="{Binding AddRegnumCommand}"
                                Content="Add"
                                Style="{StaticResource ButtonDefault}"
                                ToolTip="Add" />
                            <Button
                                Command="{Binding CopyRegnumCommand}"
                                Content="Copy"
                                Style="{StaticResource ButtonDefault}"
                                ToolTip="Copy" />
                            <Button
                                Command="{Binding SaveRegnumCommand}"
                                Content="Save"
                                Style="{StaticResource ButtonDefault}"
                                ToolTip="Save" />
                            <Button
                                Command="{Binding DeleteRegnumCommand}"
                                Content="Delete"
                                Style="{StaticResource ButtonDefault}"
                                ToolTip="Delete" />
                        </StackPanel>
                        <GroupBox Padding="3" Header="Regnums">
                            <DataGrid
                                x:Name="DataGridRegnums"
                                Width="Auto"
                                Height="200"
                                MaxHeight="400"
                                AlternatingRowBackground="BlanchedAlmond"
                                AutoGenerateColumns="False"
                                BorderBrush="DarkSlateGray"
                                BorderThickness="2"
                                CanUserAddRows="True"
                                ColumnWidth="*"
                                GridLinesVisibility="All"
                                HorizontalScrollBarVisibility="Visible"
                                IsReadOnly="False"
                                IsSynchronizedWithCurrentItem="true"
                                ItemsSource="{Binding RegnumsCollection, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                SelectedItem="{Binding SelectedRegnum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                VerticalScrollBarVisibility="Visible">

                                <DataGrid.InputBindings>
                                    <KeyBinding Command="{Binding SaveRegnumCommand}" Gesture="Ctrl+Shift+S" />
                                </DataGrid.InputBindings>
                                <DataGrid.Columns>

                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding RegnumId}"
                                        Header="Regnum ID" />
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding RegnumName}"
                                        Header="Regnum Name" />
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding Subregnum}"
                                        Header="Subregnum" />
                                    <DataGridCheckBoxColumn
                                        Width="50"
                                        Binding="{Binding Valid}"
                                        Header="Valid" />
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding ValidYear}"
                                        Header="Valid Year" />
                                    <DataGridTemplateColumn Width="300" Header="Synonym">
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox
                                                    MaxWidth="290"
                                                    MaxHeight="100"
                                                    Text="{Binding Path=Synonym, Mode=TwoWay}"
                                                    TextAlignment="Left"
                                                    TextWrapping="Wrap"
                                                    VerticalScrollBarVisibility="Visible" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    MaxWidth="290"
                                                    MaxHeight="100"
                                                    Text="{Binding Path=Synonym, Mode=OneWay}"
                                                    TextAlignment="Left"
                                                    TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding Author}"
                                        Header="Author Name" />
                                    <DataGridTextColumn
                                        Width="100"
                                        Binding="{Binding AuthorYear}"
                                        Header="Author Year" />
                                    <DataGridTemplateColumn Width="200" Header="Info">
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox
                                                    MaxWidth="190"
                                                    MaxHeight="100"
                                                    Text="{Binding Path=Info, Mode=TwoWay}"
                                                    TextAlignment="Left"
                                                    TextWrapping="Wrap"
                                                    VerticalScrollBarVisibility="Visible" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    MaxWidth="190"
                                                    MaxHeight="100"
                                                    Text="{Binding Path=Info, Mode=OneWay}"
                                                    TextAlignment="Left"
                                                    TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding EngName}"
                                        Header="EngName" />
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding GerName}"
                                        Header="GerName" />
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding FraName}"
                                        Header="FraName" />
                                    <DataGridTextColumn
                                        Width="Auto"
                                        Binding="{Binding PorName}"
                                        Header="PorName" />
                                    <DataGridTemplateColumn
                                        x:Name="ColumnMemo"
                                        Width="300"
                                        Header="Memo">
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox
                                                    MaxWidth="290"
                                                    MaxHeight="100"
                                                    Text="{Binding Path=Memo, Mode=TwoWay}"
                                                    TextAlignment="Left"
                                                    TextWrapping="Wrap"
                                                    VerticalScrollBarVisibility="Visible" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    MaxWidth="290"
                                                    MaxHeight="100"
                                                    Text="{Binding Path=Memo, Mode=OneWay}"
                                                    TextAlignment="Left"
                                                    TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </StackPanel>
                    <StackPanel Grid.Row="2">
                        <StackPanel>
                            <StackPanel>
                                <TabControl Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" SelectedIndex="{Binding TabIndexDetail, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                                    <TabItem FontWeight="DemiBold" Header="Expert-Source-Author-Comment">
                                        <GroupBox Padding="3" Header="References">
                                            <StackPanel>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <StackPanel
                                                            Grid.Row="0"
                                                            Grid.Column="0"
                                                            VerticalAlignment="Top"
                                                            Orientation="Horizontal">
                                                            <searchTextBox:SearchTextBox
                                                                x:Name="TbSearchExpert"
                                                                Width="150"
                                                                Height="30"
                                                                Margin="10,5,30,2"
                                                                AllowEmptySearches="True"
                                                                BorderBrush="LightBlue"
                                                                BorderThickness="1"
                                                                Command="{Binding GetExpertsByNameOrIdCommand}"
                                                                SearchMode="Instant"
                                                                Text="{Binding SearchExpertName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                ToolTip="SearchInfoOrId" />
                                                        </StackPanel>
                                                        <StackPanel
                                                            Grid.Row="0"
                                                            Grid.Column="0"
                                                            Margin="180,0,0,0"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            Orientation="Horizontal">
                                                            <Button
                                                                Command="{Binding AddExpertCommand}"
                                                                Content="Add"
                                                                Style="{StaticResource ButtonDefault}"
                                                                ToolTip="Add" />
                                                            <Button
                                                                Command="{Binding CopyExpertCommand}"
                                                                Content="Copy"
                                                                Style="{StaticResource ButtonDefault}"
                                                                ToolTip="Copy" />
                                                            <Button
                                                                Command="{Binding SaveExpertCommand}"
                                                                Content="Save"
                                                                Style="{StaticResource ButtonDefault}"
                                                                ToolTip="Save" />
                                                            <Button
                                                                Command="{Binding DeleteExpertCommand}"
                                                                Content="Delete"
                                                                Style="{StaticResource ButtonDefault}"
                                                                ToolTip="Delete" />
                                                        </StackPanel>
                                                        <GroupBox
                                                            Grid.Row="1"
                                                            Grid.Column="0"
                                                            Padding="3"
                                                            Header="Experts">
                                                            <DataGrid
                                                                Width="Auto"
                                                                Height="Auto"
                                                                MaxHeight="300"
                                                                AlternatingRowBackground="BlanchedAlmond"
                                                                AutoGenerateColumns="False"
                                                                BorderBrush="DarkSlateGray"
                                                                BorderThickness="2"
                                                                ColumnWidth="*"
                                                                GridLinesVisibility="All"
                                                                HorizontalScrollBarVisibility="Visible"
                                                                ItemsSource="{Binding ReferenceExpertsCollection, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                                SelectedItem="{Binding SelectedReferenceExpert, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                VerticalScrollBarVisibility="Visible">
                                                                <DataGrid.Columns>
                                                                    <DataGridTextColumn
                                                                        Width="Auto"
                                                                        Binding="{Binding ReferenceId}"
                                                                        Header="Reference ID" />
                                                                    <DataGridTextColumn
                                                                        Width="Auto"
                                                                        Binding="{Binding RefExpertId}"
                                                                        Header="Ref Expert ID" />
                                                                    <DataGridComboBoxColumn
                                                                        Width="350"
                                                                        DisplayMemberPath="RefExpertName"
                                                                        Header="Reference Expert Name"
                                                                        ItemsSource="{Binding Source={StaticResource ExpertsColl}}"
                                                                        SelectedValueBinding="{Binding RefExpertId}"
                                                                        SelectedValuePath="RefExpertId" />
                                                                    <DataGridTextColumn
                                                                        Width="Auto"
                                                                        Binding="{Binding RegnumId}"
                                                                        Header="Regnum ID" />
                                                                    <DataGridCheckBoxColumn
                                                                        Width="50"
                                                                        Binding="{Binding Valid}"
                                                                        Header="Valid" />
                                                                    <DataGridTextColumn
                                                                        Width="Auto"
                                                                        Binding="{Binding ValidYear}"
                                                                        Header="Valid Year" />
                                                                    <DataGridTemplateColumn Width="200" Header="Info">
                                                                        <DataGridTemplateColumn.CellEditingTemplate>
                                                                            <DataTemplate>
                                                                                <TextBox
                                                                                    MaxWidth="190"
                                                                                    MaxHeight="100"
                                                                                    Text="{Binding Path=Info, Mode=TwoWay}"
                                                                                    TextAlignment="Left"
                                                                                    TextWrapping="Wrap"
                                                                                    VerticalScrollBarVisibility="Visible" />
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellEditingTemplate>
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock
                                                                                    MaxWidth="190"
                                                                                    MaxHeight="100"
                                                                                    Text="{Binding Path=Info, Mode=OneWay}"
                                                                                    TextAlignment="Left"
                                                                                    TextWrapping="Wrap" />
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellTemplate>
                                                                    </DataGridTemplateColumn>
                                                                    <DataGridTemplateColumn Width="300" Header="Memo">
                                                                        <DataGridTemplateColumn.CellEditingTemplate>
                                                                            <DataTemplate>
                                                                                <TextBox
                                                                                    MaxWidth="290"
                                                                                    MaxHeight="100"
                                                                                    Text="{Binding Path=Memo, Mode=TwoWay}"
                                                                                    TextAlignment="Left"
                                                                                    TextWrapping="Wrap"
                                                                                    VerticalScrollBarVisibility="Visible" />
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellEditingTemplate>
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock
                                                                                    MaxWidth="290"
                                                                                    MaxHeight="100"
                                                                                    Text="{Binding Path=Memo, Mode=OneWay}"
                                                                                    TextAlignment="Left"
                                                                                    TextWrapping="Wrap" />
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellTemplate>
                                                                    </DataGridTemplateColumn>
                                                                </DataGrid.Columns>
                                                            </DataGrid>
                                                        </GroupBox>
                                                    </Grid>
                                                </StackPanel>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <StackPanel
                                                            Grid.Row="0"
                                                            Grid.Column="0"
                                                            VerticalAlignment="Top"
                                                            Orientation="Horizontal">
                                                            <searchTextBox:SearchTextBox
                                                                x:Name="TbSearchSource"
                                                                Width="150"
                                                                Height="30"
                                                                Margin="10,5,30,2"
                                                                AllowEmptySearches="True"
                                                                BorderBrush="LightBlue"
                                                                BorderThickness="1"
                                                                Command="{Binding GetSourcesByNameOrIdCommand}"
                                                                SearchMode="Instant"
                                                                Text="{Binding SearchSourceName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                ToolTip="SearchInfoOrId" />
                                                        </StackPanel>
                                                        <StackPanel
                                                            Grid.Row="0"
                                                            Grid.Column="0"
                                                            Margin="180,0,0,0"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            Orientation="Horizontal">
                                                            <Button
                                                                Command="{Binding AddSourceCommand}"
                                                                Content="Add"
                                                                Style="{StaticResource ButtonDefault}"
                                                                ToolTip="Add" />
                                                            <Button
                                                                Command="{Binding CopySourceCommand}"
                                                                Content="Copy"
                                                                Style="{StaticResource ButtonDefault}"
                                                                ToolTip="Copy" />
                                                            <Button
                                                                Command="{Binding SaveSourceCommand}"
                                                                Content="Save"
                                                                Style="{StaticResource ButtonDefault}"
                                                                ToolTip="Save" />
                                                            <Button
                                                                Command="{Binding DeleteSourceCommand}"
                                                                Content="Delete"
                                                                Style="{StaticResource ButtonDefault}"
                                                                ToolTip="Delete" />
                                                        </StackPanel>
                                                        <GroupBox
                                                            Grid.Row="1"
                                                            Grid.Column="0"
                                                            Padding="3"
                                                            Header="Sources">
                                                            <DataGrid
                                                                Width="Auto"
                                                                Height="Auto"
                                                                MaxHeight="300"
                                                                AlternatingRowBackground="BlanchedAlmond"
                                                                AutoGenerateColumns="False"
                                                                BorderBrush="DarkSlateGray"
                                                                BorderThickness="2"
                                                                ColumnWidth="*"
                                                                HorizontalScrollBarVisibility="Visible"
                                                                ItemsSource="{Binding ReferenceSourcesCollection, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                                SelectedItem="{Binding SelectedReferenceSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                VerticalScrollBarVisibility="Visible">
                                                                <DataGrid.Columns>
                                                                    <DataGridTextColumn
                                                                        Width="Auto"
                                                                        Binding="{Binding ReferenceId}"
                                                                        Header="Reference ID" />
                                                                    <DataGridTextColumn
                                                                        Width="Auto"
                                                                        Binding="{Binding RefSourceId}"
                                                                        Header="Ref Source ID" />
                                                                    <DataGridComboBoxColumn
                                                                        Width="350"
                                                                        DisplayMemberPath="RefSourceName"
                                                                        Header="Reference Source Name"
                                                                        ItemsSource="{Binding Source={StaticResource SourcesColl}}"
                                                                        SelectedValueBinding="{Binding RefSourceId}"
                                                                        SelectedValuePath="RefSourceId" />
                                                                    <DataGridTextColumn
                                                                        Width="Auto"
                                                                        Binding="{Binding RegnumId}"
                                                                        Header="Regnum ID" />
                                                                    <DataGridCheckBoxColumn
                                                                        Width="50"
                                                                        Binding="{Binding Valid}"
                                                                        Header="Valid" />
                                                                    <DataGridTextColumn
                                                                        Width="Auto"
                                                                        Binding="{Binding ValidYear}"
                                                                        Header="Valid Year" />
                                                                    <DataGridTemplateColumn Width="200" Header="Info">
                                                                        <DataGridTemplateColumn.CellEditingTemplate>
                                                                            <DataTemplate>
                                                                                <TextBox
                                                                                    MaxWidth="190"
                                                                                    MaxHeight="100"
                                                                                    Text="{Binding Path=Info, Mode=TwoWay}"
                                                                                    TextAlignment="Left"
                                                                                    TextWrapping="Wrap"
                                                                                    VerticalScrollBarVisibility="Visible" />
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellEditingTemplate>
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock
                                                                                    MaxWidth="190"
                                                                                    MaxHeight="100"
                                                                                    Text="{Binding Path=Info, Mode=OneWay}"
                                                                                    TextAlignment="Left"
                                                                                    TextWrapping="Wrap" />
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellTemplate>
                                                                    </DataGridTemplateColumn>
                                                                    <DataGridTemplateColumn Width="300" Header="Memo">
                                                                        <DataGridTemplateColumn.CellEditingTemplate>
                                                                            <DataTemplate>
                                                                                <TextBox
                                                                                    MaxWidth="290"
                                                                                    MaxHeight="100"
                                                                                    Text="{Binding Path=Memo, Mode=TwoWay}"
                                                                                    TextAlignment="Left"
                                                                                    TextWrapping="Wrap"
                                                                                    VerticalScrollBarVisibility="Visible" />
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellEditingTemplate>
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock
                                                                                    MaxWidth="290"
                                                                                    MaxHeight="100"
                                                                                    Text="{Binding Path=Memo, Mode=OneWay}"
                                                                                    TextAlignment="Left"
                                                                                    TextWrapping="Wrap" />
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellTemplate>
                                                                    </DataGridTemplateColumn>
                                                                </DataGrid.Columns>
                                                            </DataGrid>
                                                        </GroupBox>
                                                    </Grid>
                                                    <Grid />
                                                </StackPanel>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <StackPanel
                                                            Grid.Row="0"
                                                            Grid.Column="0"
                                                            VerticalAlignment="Top"
                                                            Orientation="Horizontal" />
                                                        <StackPanel
                                                            Grid.Row="0"
                                                            Grid.Column="0"
                                                            VerticalAlignment="Top"
                                                            Orientation="Horizontal">
                                                            <searchTextBox:SearchTextBox
                                                                x:Name="TbSearchAuthor"
                                                                Width="150"
                                                                Height="30"
                                                                Margin="10,5,30,2"
                                                                AllowEmptySearches="True"
                                                                BorderBrush="LightBlue"
                                                                BorderThickness="1"
                                                                Command="{Binding GetAuthorsByNameOrIdCommand}"
                                                                SearchMode="Instant"
                                                                Text="{Binding SearchAuthorName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                ToolTip="SearchInfoOrId" />
                                                        </StackPanel>

                                                        <StackPanel
                                                            Grid.Row="0"
                                                            Grid.Column="0"
                                                            Margin="180,0,0,0"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            Orientation="Horizontal">
                                                            <Button
                                                                Command="{Binding AddAuthorCommand}"
                                                                Content="Add"
                                                                Style="{StaticResource ButtonDefault}"
                                                                ToolTip="Add" />
                                                            <Button
                                                                Command="{Binding CopyAuthorCommand}"
                                                                Content="Copy"
                                                                Style="{StaticResource ButtonDefault}"
                                                                ToolTip="Copy" />
                                                            <Button
                                                                Command="{Binding SaveAuthorCommand}"
                                                                Content="Save"
                                                                Style="{StaticResource ButtonDefault}"
                                                                ToolTip="Save" />
                                                            <Button
                                                                Command="{Binding DeleteAuthorCommand}"
                                                                Content="Delete"
                                                                Style="{StaticResource ButtonDefault}"
                                                                ToolTip="Delete" />
                                                        </StackPanel>
                                                        <GroupBox
                                                            Grid.Row="1"
                                                            Grid.Column="0"
                                                            Padding="3"
                                                            Header="Authors">
                                                            <DataGrid
                                                                Width="Auto"
                                                                Height="Auto"
                                                                MaxHeight="300"
                                                                AlternatingRowBackground="BlanchedAlmond"
                                                                AutoGenerateColumns="False"
                                                                BorderBrush="DarkSlateGray"
                                                                BorderThickness="2"
                                                                ColumnWidth="*"
                                                                HorizontalScrollBarVisibility="Visible"
                                                                ItemsSource="{Binding ReferenceAuthorsCollection, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                                SelectedItem="{Binding SelectedReferenceAuthor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                VerticalScrollBarVisibility="Visible">
                                                                <DataGrid.Columns>
                                                                    <DataGridTextColumn
                                                                        Width="Auto"
                                                                        Binding="{Binding ReferenceId}"
                                                                        Header="Reference ID" />
                                                                    <DataGridTextColumn
                                                                        Width="Auto"
                                                                        Binding="{Binding RefAuthorId}"
                                                                        Header="Ref Author ID" />
                                                                    <DataGridComboBoxColumn
                                                                        Width="500"
                                                                        DisplayMemberPath="RefAuthorName"
                                                                        Header="Reference Author Name"
                                                                        ItemsSource="{Binding Source={StaticResource AuthorsColl}}"
                                                                        SelectedValueBinding="{Binding RefAuthorId}"
                                                                        SelectedValuePath="RefAuthorId" />
                                                                    <DataGridTextColumn
                                                                        Width="Auto"
                                                                        Binding="{Binding RegnumId}"
                                                                        Header="Regnum ID" />
                                                                    <DataGridCheckBoxColumn
                                                                        Width="50"
                                                                        Binding="{Binding Valid}"
                                                                        Header="Valid" />
                                                                    <DataGridTextColumn
                                                                        Width="Auto"
                                                                        Binding="{Binding ValidYear}"
                                                                        Header="Valid Year" />
                                                                    <DataGridTemplateColumn Width="200" Header="Info">
                                                                        <DataGridTemplateColumn.CellEditingTemplate>
                                                                            <DataTemplate>
                                                                                <TextBox
                                                                                    MaxWidth="190"
                                                                                    MaxHeight="100"
                                                                                    Text="{Binding Path=Info, Mode=TwoWay}"
                                                                                    TextAlignment="Left"
                                                                                    TextWrapping="Wrap"
                                                                                    VerticalScrollBarVisibility="Visible" />
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellEditingTemplate>
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock
                                                                                    MaxWidth="190"
                                                                                    MaxHeight="100"
                                                                                    Text="{Binding Path=Info, Mode=OneWay}"
                                                                                    TextAlignment="Left"
                                                                                    TextWrapping="Wrap" />
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellTemplate>
                                                                    </DataGridTemplateColumn>
                                                                    <DataGridTemplateColumn Width="300" Header="Memo">
                                                                        <DataGridTemplateColumn.CellEditingTemplate>
                                                                            <DataTemplate>
                                                                                <TextBox
                                                                                    MaxWidth="290"
                                                                                    MaxHeight="100"
                                                                                    Text="{Binding Path=Memo, Mode=TwoWay}"
                                                                                    TextAlignment="Left"
                                                                                    TextWrapping="Wrap"
                                                                                    VerticalScrollBarVisibility="Visible" />
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellEditingTemplate>
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock
                                                                                    MaxWidth="290"
                                                                                    MaxHeight="100"
                                                                                    Text="{Binding Path=Memo, Mode=OneWay}"
                                                                                    TextAlignment="Left"
                                                                                    TextWrapping="Wrap" />
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellTemplate>
                                                                    </DataGridTemplateColumn>
                                                                </DataGrid.Columns>

                                                            </DataGrid>
                                                        </GroupBox>
                                                    </Grid>
                                                    <Grid />
                                                </StackPanel>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <StackPanel
                                                            Grid.Row="0"
                                                            Grid.Column="0"
                                                            VerticalAlignment="Top"
                                                            Orientation="Horizontal">
                                                            <searchTextBox:SearchTextBox
                                                                x:Name="TbSearchComment"
                                                                Width="150"
                                                                Height="30"
                                                                Margin="10,5,30,2"
                                                                AllowEmptySearches="True"
                                                                BorderBrush="LightBlue"
                                                                BorderThickness="1"
                                                                Command="{Binding GetCommentsByNameOrIdCommand}"
                                                                SearchMode="Instant"
                                                                Text="{Binding SearchCommentName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                ToolTip="SearchInfoOrId" />
                                                        </StackPanel>

                                                        <StackPanel
                                                            Grid.Row="0"
                                                            Grid.Column="0"
                                                            Margin="180,0,0,0"
                                                            HorizontalAlignment="Left"
                                                            Orientation="Horizontal">
                                                            <Button
                                                                Command="{Binding AddCommentCommand}"
                                                                Content="Add"
                                                                Style="{StaticResource ButtonDefault}"
