                                                                Binding="{Binding FraName}"
                                                                Header="{DynamicResource Shared-FraName}" />
                                                            <DataGridTextColumn
                                                                Width="Auto"
                                                                Binding="{Binding PorName}"
                                                                Header="{DynamicResource Shared-SpaName}" />
                                                            <DataGridTemplateColumn Width="300" Header="{DynamicResource Shared-Memo}">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock
                                                                            MaxWidth="290"
                                                                            MaxHeight="100"
                                                                            Text="{Binding Path=Memo, Mode=OneWay}"
                                                                            TextAlignment="Left"
                                                                            TextWrapping="Wrap" />
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </GroupBox>
                                            </Grid>
                                        </StackPanel>
                                    </TabItem>
                                </TabControl>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
