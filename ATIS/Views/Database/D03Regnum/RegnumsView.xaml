                                                    HorizontalScrollBarVisibility="Visible"
                                                    IsReadOnly="True"
                                                    IsSynchronizedWithCurrentItem="true"
                                                    ItemsSource="{Binding SubdivisionsCollection, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                    SelectedItem="{Binding SelectedSubdivision, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    VerticalScrollBarVisibility="Visible">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn
                                                            Width="Auto"
                                                            Binding="{Binding SubdivisionId}"
                                                            Header="{DynamicResource Tbl15Subdivision-SubdivisionId}" />
                                                        <DataGridTextColumn
                                                            Width="Auto"
                                                            Binding="{Binding SubdivisionName}"
                                                            Header="{DynamicResource Tbl15Subdivision-SubdivisionName}" />
                                                        <DataGridTextColumn
                                                            Width="Auto"
                                                            Binding="{Binding DivisionId}"
                                                            Header="{DynamicResource Tbl09Division-DivisionId}" />
                                                        <DataGridComboBoxColumn
                                                            Width="Auto"
                                                            DisplayMemberPath="DivisionName"
                                                            Header="{DynamicResource Tbl09Division-DivisionName}"
                                                            ItemsSource="{Binding Source={StaticResource DivisionsAllColl}}"
                                                            SelectedValueBinding="{Binding (models:Tbl09Division.DivisionId)}"
                                                            SelectedValuePath="DivisionId" />
                                                        <DataGridCheckBoxColumn
                                                            Width="Auto"
                                                            Binding="{Binding Valid}"
                                                            Header="{DynamicResource Shared-Valid}" />
                                                        <DataGridTextColumn
                                                            Width="Auto"
                                                            Binding="{Binding ValidYear}"
                                                            Header="{DynamicResource Shared-ValidYear}" />
                                                        <DataGridTemplateColumn Width="300" Header="{DynamicResource Shared-Synonym}">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock
                                                                        MaxWidth="290"
                                                                        MaxHeight="100"
                                                                        Text="{Binding Path=Synonym, Mode=OneWay}"
                                                                        TextAlignment="Left"
                                                                        TextWrapping="Wrap" />
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTextColumn
                                                            Width="Auto"
                                                            Binding="{Binding Author}"
                                                            Header="{DynamicResource Shared-Author}" />
                                                        <DataGridTextColumn
                                                            Width="Auto"
                                                            Binding="{Binding AuthorYear}"
                                                            Header="{DynamicResource Shared-AuthorYear}" />
                                                        <DataGridTemplateColumn Width="200" Header="{DynamicResource Shared-Info}">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock
                                                                        MaxWidth="190"
                                                                        MaxHeight="100"
                                                                        Text="{Binding Path=Info, Mode=OneWay}"
                                                                        TextAlignment="Left"
                                                                        TextWrapping="Wrap" />
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTextColumn
                                                            Width="Auto"
                                                            Binding="{Binding EngName}"
                                                            Header="{DynamicResource Shared-EngName}" />
                                                        <DataGridTextColumn
                                                            Width="Auto"
                                                            Binding="{Binding GerName}"
                                                            Header="{DynamicResource Shared-GerName}" />
                                                        <DataGridTextColumn
                                                            Width="Auto"
                                                            Binding="{Binding FraName}"
                                                            Header="{DynamicResource Shared-FraName}" />
                                                        <DataGridTextColumn
                                                            Width="Auto"
                                                            Binding="{Binding PorName}"
                                                            Header="{DynamicResource Shared-SpaName}" />
                                                        <DataGridTemplateColumn Width="600" Header="{DynamicResource Shared-Memo}">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock
                                                                        MaxWidth="590"
                                                                        MaxHeight="100"
                                                                        Text="{Binding Path=Memo, Mode=OneWay}"
                                                                        TextAlignment="Left"
                                                                        TextWrapping="Wrap" />
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Grid>
                                        </ScrollViewer>
                                    </GroupBox>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
