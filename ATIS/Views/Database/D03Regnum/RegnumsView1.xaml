                                                                FontWeight="Normal"
                                                                IsChecked="{Binding SelectedItem.(models:Tbl90Reference.Valid), ElementName=Tbl90ReferenceAuthorsList}" />
                                                            <TextBox Width="50" Margin="25,0,0,0">
                                                                <TextBox.Text>
                                                                    <Binding
                                                                        ElementName="Tbl90ReferenceAuthorsList"
                                                                        Mode="TwoWay"
                                                                        Path="SelectedItem.(models:Tbl90Reference.ValidYear)"
                                                                        UpdateSourceTrigger="PropertyChanged" />
                                                                </TextBox.Text>
                                                            </TextBox>
                                                        </StackPanel>
                                                        <StackPanel Height="Auto" Orientation="Horizontal">
                                                            <TextBox Width="760" Margin="5,0,0,0">
                                                                <TextBox.Text>
                                                                    <Binding
                                                                        ElementName="Tbl90ReferenceAuthorsList"
                                                                        Mode="TwoWay"
                                                                        Path="SelectedItem.(models:Tbl90Reference.Info)"
                                                                        UpdateSourceTrigger="PropertyChanged" />
                                                                </TextBox.Text>
                                                            </TextBox>
                                                        </StackPanel>

                                                        <StackPanel Height="Auto" Orientation="Horizontal">
                                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                                <TextBox
                                                                    Height="Auto"
                                                                    MinWidth="760"
                                                                    MinHeight="100"
                                                                    MaxWidth="760"
                                                                    MaxHeight="400"
                                                                    Margin="5,0,0,5"
                                                                    VerticalAlignment="Stretch"
                                                                    AcceptsReturn="True"
                                                                    Text="{Binding SelectedItem.(models:Tbl90Reference.Memo), ElementName=Tbl90ReferenceAuthorsList}"
                                                                    TextWrapping="Wrap"
                                                                    VerticalScrollBarVisibility="Auto" />
                                                            </ScrollViewer>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </GroupBox>
                                            </TabItem>
                                        </TabControl>
                                    </GroupBox>
                                </TabItem>

                                <!--  Part 14  -->

                                <TabItem FontWeight="Medium" Header="Comment">
                                    <GroupBox>
                                        <StackPanel Margin="0,8,5,0">
                                            <StackPanel Height="Auto" Orientation="Horizontal">
                                                <Button
                                                    Width="50"
                                                    Margin="0,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding SaveCommentCommand}"
                                                    Content="Save"
                                                    ToolTip="Save" />
                                                <Button
                                                    Width="50"
                                                    Margin="0,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding CopyCommentCommand}"
                                                    Content="Copy"
                                                    ToolTip="Copy" />
                                                <Button
                                                    Width="50"
                                                    Margin="0,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding AddCommentCommand}"
                                                    Content="Add"
                                                    ToolTip="Create" />
                                                <Button
                                                    Width="50"
                                                    Margin="0,0,0,0"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding DeleteCommentCommand}"
                                                    Content="Delete"
                                                    ToolTip="Delete" />
                                            </StackPanel>
                                            <StackPanel Height="Auto" Orientation="Horizontal">
                                                <CheckBox
                                                    Width="80"
                                                    Margin="5,19,0,0"
                                                    VerticalAlignment="Bottom"
                                                    Content="Valid"
                                                    FontWeight="Normal"
                                                    IsChecked="{Binding SelectedItem.(models:Tbl93Comment.Valid), ElementName=Tbl93CommentsList}" />
                                            </StackPanel>
                                            <StackPanel Height="Auto" Orientation="Horizontal">
                                                <TextBox Width="760" Margin="5,0,0,0">
                                                    <TextBox.Text>
                                                        <Binding
                                                            ElementName="Tbl93CommentsList"
                                                            Mode="TwoWay"
                                                            Path="SelectedItem.(models:Tbl93Comment.Info)"
                                                            UpdateSourceTrigger="PropertyChanged" />
                                                    </TextBox.Text>
                                                </TextBox>
                                            </StackPanel>

                                            <StackPanel Height="Auto" Orientation="Horizontal">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <TextBox
                                                        Height="Auto"
                                                        MinWidth="760"
                                                        MinHeight="100"
                                                        MaxWidth="760"
                                                        MaxHeight="620"
                                                        Margin="5,0,0,5"
                                                        VerticalAlignment="Stretch"
                                                        AcceptsReturn="True"
                                                        Text="{Binding SelectedItem.(models:Tbl93Comment.Memo), ElementName=Tbl93CommentsList}"
                                                        TextWrapping="Wrap"
                                                        VerticalScrollBarVisibility="Auto" />
                                                </ScrollViewer>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </TabItem>
                            </TabControl>
                        </GroupBox>
                    </TabItem>
                </TabControl>
            </Grid>
        </ScrollViewer>

        <GridSplitter
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="1"
            Width="5"
            HorizontalAlignment="Stretch"
            Background="Gray"
            ResizeDirection="Columns"
            ShowsPreview="False" />
    </Grid>
</UserControl>
