                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <CheckBox IsChecked="{Binding (models:Tbl03Regnum.Valid)}" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>

                                                <GridViewColumn
                                                    Width="150"
                                                    DisplayMemberBinding="{Binding (models:Tbl03Regnum.Author)}"
                                                    Header="Author" />
                                                <GridViewColumn
                                                    Width="80"
                                                    DisplayMemberBinding="{Binding (models:Tbl03Regnum.AuthorYear)}"
                                                    Header="AuthorYear" />

                                                <GridViewColumn
                                                    Width="400"
                                                    DisplayMemberBinding="{Binding (models:Tbl03Regnum.Info)}"
                                                    Header="Info" />

                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </StackPanel>
                            </ScrollViewer>
