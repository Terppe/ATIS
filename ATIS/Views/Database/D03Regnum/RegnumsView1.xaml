                SelectedIndex="{Binding MainTabIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <TabItem FontWeight="DemiBold" Header="Regnums">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="25" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <StackPanel
                                HorizontalAlignment="Left"
                                FocusManager.FocusedElement="{Binding ElementName=TbSearch}"
                                Orientation="Horizontal">
                                <searchTextBox:SearchTextBox
                                    x:Name="TbSearch"
                                    Width="150"
                                    Margin="5,0,10,0"
                                    AllowEmptySearches="True"
                                    Command="{Binding GetRegnumsByNameOrIdCommand}"
                                    FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}"
                                    SearchMode="Instant"
                                    Text="{Binding SearchRegnumName, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                    ToolTip="SearchNameOrId" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                                <Button
                                    Command="{Binding AddRegnumCommand}"
                                    Content="Add"
                                    Style="{StaticResource AtisFlatButton}"
                                    ToolTip="Add" />
                            </StackPanel>
                        </DockPanel>
                        <DockPanel Grid.Row="1">
                            <ScrollViewer
                                Margin="0,5,0,0"
                                HorizontalScrollBarVisibility="Auto"
                                VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <ListView
                                        x:Name="Tbl03RegnumsList"
                                        IsSynchronizedWithCurrentItem="True"
                                        ItemsSource="{Binding RegnumsList}"
                                        ScrollViewer.IsDeferredScrollingEnabled="True"
                                        SelectedItem="{Binding (Selector.SelectedItem)}"
                                        VirtualizingStackPanel.IsVirtualizing="True"
                                        VirtualizingStackPanel.VirtualizationMode="Recycling">

                                        <!--  trigger  -->
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseDoubleClick">
                                                <i:InvokeCommandAction Command="{Binding GetConnectedTablesCommand}" CommandParameter="{Binding ElementName=Tbl03RegnumsList, Path=SelectedItem}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>



                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Width="Auto" Header="RegnumId">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock
                                                                Width="100"
                                                                Text="{Binding (models:Tbl03Regnum.RegnumId)}"
                                                                TextAlignment="Left" />
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn
                                                    Width="150"
                                                    DisplayMemberBinding="{Binding (models:Tbl03Regnum.RegnumName)}"
                                                    Header="RegnumName" />
                                                <GridViewColumn
                                                    Width="150"
                                                    DisplayMemberBinding="{Binding (models:Tbl03Regnum.Subregnum)}"
