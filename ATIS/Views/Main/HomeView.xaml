                <Border  
                    Margin="0,8,0,0"
                    BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                    BorderThickness="1" Width="Auto">
                    <Grid Margin="8">
                        <Button
                            Width="120"
                            HorizontalAlignment="Left"
                            Click="GitHubButton_OnClick"
                            Style="{DynamicResource MahApps.Styles.Button}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconModern
                                    Width="30"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Kind="SocialGithub" />
                                <TextBlock
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="GitHub" />
                            </StackPanel>
                        </Button>
                        <Button
                            Width="120"
                            Margin="130,0,0,0"
                            HorizontalAlignment="Left"
                            Click="EmailButton_OnClick"
                            Style="{DynamicResource MahApps.Styles.Button}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconModern
                                    Width="30"
                                    Height="30"
                                    Margin="8,0,0,0"
                                    Kind="Email" />
                                <TextBlock
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="Email" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
