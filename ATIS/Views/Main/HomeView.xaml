            <StackPanel
                Grid.Column="1"
                Margin="24,20,0,0"
                VerticalAlignment="Center">
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="20"
                    Style="{DynamicResource DescriptionHeaderStyle}"
                    Text="{DynamicResource MainWindow-Welcome}"
                    TextWrapping="Wrap" />
            </StackPanel>
