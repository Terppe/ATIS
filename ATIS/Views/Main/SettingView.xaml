<UserControl
    x:Class="ATIS.Ui.Views.Main.SettingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ATIS.Ui.Views.Main"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <Label FontSize="30" FontWeight="Bold">WPF Window</Label>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="10">
            <Label FontSize="25" FontWeight="Bold">Theme Settings</Label>
            <RadioButton
                x:Name="RdDark"
                Margin="10"
                Checked="RadioButtonChecked"
                FontSize="25"
                Tag="Dark">
                Dark
            </RadioButton>
            <RadioButton
                x:Name="RdLight"
                Margin="10"
                Checked="RadioButtonChecked"
                FontSize="25"
                Tag="light">
                Light
            </RadioButton>
        </StackPanel>

    </Grid>
</UserControl>
