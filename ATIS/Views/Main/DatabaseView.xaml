<UserControl
    x:Class="ATIS.Views.Main.DatabaseView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:database="clr-namespace:ATIS.Views.Database"
    xmlns:local="clr-namespace:ATIS.Views.Main"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate DataType="{x:Type database:Tbl06PhylumsViewModel}">
            <database:Tbl06PhylumsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type database:Tbl03RegnumsViewModel}">
            <database:Tbl03RegnumsView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <TabControl>
            <TabItem Header="Fishes" />
            <TabControl>
                <TabItem Header="FiSpecies">
                    <TabItem Content="{Binding Tbl03RegnumsView}" Header="Regnum" />

                </TabItem>
            </TabControl>
        </TabControl>
        <Label
            x:Name="LbVersion"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Content="Database" />
        <ContentControl Content="{Binding ElementName=Tbl, Path=SelectedItem}" />

    </Grid>
</UserControl>
