                <ResourceDictionary Source="CultRes/StringsRes.fr-FR.xaml" />
                <ResourceDictionary Source="CultRes/StringsRes.pt-PT.xaml" />

                <!--<ResourceDictionary Source="pack://application:,,,/ATIS.Styles;component/StylesDictionary.xaml" />-->

                <ResourceDictionary Source="Asset/Styles.xaml" />
